---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import AboutSection from "@/components/home/AboutSection.astro";
import Testimonials from "@/components/home/Testimonials.astro";
import FAQ from "@/components/home/FAQ.astro";
import ScrollReveal from "@/components/ui/ScrollReveal.astro";
import ProjectCard from "@/components/projects/ProjectCard.astro";
import Button from "@/components/ui/Button.astro";
import { siteConfig } from "@/config/site";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

import framingImg from "@/assets/projects/framing-01.webp";
import interiorImg from "@/assets/projects/interior-01.webp";
import decksImg from "@/assets/projects/decks-01.webp";
import carpentryImg from "@/assets/projects/carpentry-01.webp";
import baseboardsImg from "@/assets/projects/baseboards-01.webp";
import woodrotImg from "@/assets/projects/woodrot-01.webp";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Get featured projects
const allProjects = await getCollection("projects");
const featuredProjects = allProjects
	.filter((project: CollectionEntry<"projects">) => project.data.featured)
	.sort(
		(a: CollectionEntry<"projects">, b: CollectionEntry<"projects">) =>
			b.data.date.getTime() - a.data.date.getTime(),
	)
	.slice(0, 3);
---

<Layout title={siteConfig.title} description={siteConfig.description}>
	<ScrollReveal />
	<!-- Hero Section -->
	<section
		class="relative min-h-[90vh] flex items-center justify-center text-white py-24 md:py-32 overflow-hidden"
	>
		<!-- Background Image with Overlay -->
		<div class="absolute inset-0 z-0">
			<img
				src="https://images.unsplash.com/photo-1541888086925-920a0bfaadc8?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80"
				alt="Fondo de construcción"
				class="w-full h-full object-cover"
			/>
			<div
				class="absolute inset-0 bg-gradient-to-r from-gray-900/95 via-gray-900/80 to-gray-800/60 backdrop-blur-[2px]"
			>
			</div>
		</div>

		<div class="container mx-auto px-4 relative z-10">
			<div class="max-w-4xl mx-auto text-center relative py-8">
				<div class="absolute inset-0 flex justify-center items-center opacity-15 pointer-events-none -z-10">
					<img 
						src={(await import("@/assets/logo/logo-transparente.png")).default.src} 
						alt="" 
						class="w-full max-w-3xl h-auto"
						loading="eager"
					/>
				</div>
				<h1
					class="text-5xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight"
				>
					{t("hero.title").split(" Phoenix")[0]}
					<span class="text-blue-400">Phoenix, AZ</span>
				</h1>
				<p
					class="text-xl md:text-2xl text-gray-300 mb-8 leading-relaxed"
				>
					{t("hero.subtitle")}
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<Button
						href="/es/contacto"
						variant="primary"
						size="lg"
					>
						{t("hero.cta")}
					</Button>
					<Button
						href="/es/proyectos"
						variant="outline"
						size="lg"
						class="border-white text-white hover:bg-white hover:text-gray-900"
					>
						{t("hero.cta2")}
					</Button>
				</div>

				<!-- Quick Stats -->
				<div
					class="grid grid-cols-3 gap-6 mt-16 pt-16 border-t border-gray-700"
				>
					<div>
						<div class="text-4xl font-bold text-blue-400 mb-2">
							10+
						</div>
						<div class="text-gray-400">{t("stats.years")}</div>
					</div>
					<div>
						<div class="text-4xl font-bold text-blue-400 mb-2">
							500+
						</div>
						<div class="text-gray-400">{t("stats.projects")}</div>
					</div>
					<div>
						<div class="text-4xl font-bold text-blue-400 mb-2">
							100%
						</div>
						<div class="text-gray-400">
							{t("stats.satisfaction")}
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- About Section -->
	<AboutSection />

	<!-- Services Section -->
	<section
		class="py-20 bg-gray-50 dark:bg-slate-900 transition-colors duration-300"
	>
		<div class="container mx-auto px-4">
			<div class="text-center mb-16 reveal-on-scroll reveal-fade-up">
				<h2
					class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4"
				>
					{t("services.title")}
				</h2>
				<p
					class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto"
				>
					{t("services.subtitle")}
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{
					siteConfig.business.serviceTypes.map((service, index) => {
						const images = [
							framingImg,
							interiorImg,
							decksImg,
							carpentryImg,
							baseboardsImg,
							woodrotImg,
						];
						return (
							<div
								class={`bg-white dark:bg-slate-800 rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 group reveal-on-scroll reveal-fade-up delay-${((index % 3) + 1) * 100}`}
							>
								<div class="h-56 overflow-hidden relative">
									<img
										src={images[index % images.length].src}
										alt={t(`service.${service}` as any) || service}
										class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
										loading="lazy"
									/>
									<div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
										<a href={lang === "es" ? "/es/contacto" : "/contacto"} class="text-white font-semibold bg-blue-600/90 hover:bg-blue-600 px-6 py-2 rounded-lg backdrop-blur-sm transition-colors w-full text-center">
											{lang === "es" ? "Solicitar Presupuesto" : "Request Estimate"}
										</a>
									</div>
								</div>
								<div class="p-8 border-t border-gray-100 dark:border-gray-700">
									<h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">
										{t(`service.${service}` as any) || service}
									</h3>
									<p class="text-gray-600 dark:text-gray-400">
										{t("services.descPrefix")}
										{(t(`service.${service}` as any) || service).toLowerCase()}
										{t("services.descSuffix")}
									</p>
								</div>
							</div>
						);
					})
				}
			</div>
		</div>
	</section>

	<!-- Featured Projects Section -->
	{
		featuredProjects.length > 0 && (
			<section class="py-20 bg-white dark:bg-slate-900 transition-colors duration-300">
				<div class="container mx-auto px-4">
					<div class="text-center mb-16 reveal-on-scroll reveal-fade-up">
						<h2 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
							{t("featured.title")}
						</h2>
						<p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
							{t("featured.subtitle")}
						</p>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
						{featuredProjects.map(
							(project: CollectionEntry<"projects">, index) => (
								<div
									class={`reveal-on-scroll reveal-fade-up delay-${((index % 3) + 1) * 100}`}
								>
									<ProjectCard project={project} />
								</div>
							),
						)}
					</div>

					<div class="text-center reveal-on-scroll reveal-fade-up delay-400">
						<Button href="/es/proyectos" variant="primary" size="lg">
							{t("featured.viewAll")}
						</Button>
					</div>
				</div>
			</section>
		)
	}

	<!-- Testimonials Section -->
	<Testimonials />

	<!-- FAQ Section -->
	<FAQ />

	<!-- Call to Action Section -->
	<section
		class="py-20 bg-blue-600 dark:bg-blue-900 text-white relative overflow-hidden transition-colors duration-300"
	>
		<div class="absolute inset-0 z-0 opacity-10">
			<svg class="absolute w-full h-full" xmlns="http://www.w3.org/2000/svg">
				<defs>
					<pattern id="grid-es" width="40" height="40" patternUnits="userSpaceOnUse">
						<path d="M0 40V0H40V40H0ZM39 39V1H1V39H39Z" fill="currentColor"></path>
					</pattern>
				</defs>
				<rect width="100%" height="100%" fill="url(#grid-es)"></rect>
			</svg>
		</div>

		<div class="container mx-auto px-4 text-center relative z-10 reveal-on-scroll reveal-scale">
			<h2 class="text-4xl md:text-5xl font-bold mb-6">{t("cta.title")}</h2>
			<p class="text-xl mb-8 max-w-2xl mx-auto opacity-90">{t("cta.subtitle")}</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<Button href="/es/contacto" variant="secondary" size="lg">
					{t("cta.button")}
				</Button>
				<Button
					href={`tel:${siteConfig.author.phone}`}
					variant="outline"
					size="lg"
					class="border-white text-white hover:bg-white hover:text-blue-600"
				>
					<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
					</svg>
					{siteConfig.author.phone}
				</Button>
			</div>
		</div>
	</section>

	<!-- Service Areas Section -->
	<section class="py-16 bg-gray-50 dark:bg-slate-900 transition-colors duration-300">
		<div class="container mx-auto px-4 text-center reveal-on-scroll reveal-fade-up">
			<h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">{t("areas.title")}</h3>
			<div class="flex flex-wrap justify-center gap-4">
				{siteConfig.business.areaServed.map((area) => (
					<span class="bg-gray-100 dark:bg-slate-800 text-gray-700 dark:text-gray-300 px-6 py-2 rounded-full font-medium border border-transparent dark:border-slate-700">
						{area}
					</span>
				))}
			</div>
		</div>
	</section>
</Layout>
