---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import ProjectCard from "@/components/projects/ProjectCard.astro";

const allProjects = await getCollection("projects");
const projects = allProjects.sort(
    (a: CollectionEntry<"projects">, b: CollectionEntry<"projects">) =>
        b.data.date.getTime() - a.data.date.getTime(),
);

const categories = [
    "Todos",
    ...new Set(projects.map((p: CollectionEntry<"projects">) => p.data.category)),
];
---

<Layout
    title="Proyectos de Carpintería y Remodelación"
    description="Explora nuestros proyectos de framing, remodelación y carpintería personalizada en Phoenix, Scottsdale, Mesa y Tempe."
>
    <div class="container mx-auto px-4 py-16">
        <div class="text-center mb-12">
            <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-gray-100 mb-4">Nuestros Proyectos</h1>
            <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
                Cada proyecto representa nuestro compromiso con la calidad y la satisfacción del cliente.
            </p>
        </div>

        <div class="flex flex-wrap justify-center gap-3 mb-12">
            {categories.map((category) => (
                <button class="category-filter-es px-6 py-2 rounded-full font-semibold transition-all duration-200 border-2" data-category={category}>
                    {category}
                </button>
            ))}
        </div>

        {projects.length > 0 ? (
            <div id="projects-grid-es" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {projects.map((project: CollectionEntry<"projects">) => (
                    <div class="project-item-es" data-category={project.data.category}>
                        <ProjectCard project={project} />
                    </div>
                ))}
            </div>
        ) : (
            <div class="text-center py-16">
                <p class="text-gray-500 dark:text-gray-400 text-lg">Pronto añadiremos proyectos aquí. ¡Mantente al pendiente!</p>
            </div>
        )}
    </div>
</Layout>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const filterButtons = document.querySelectorAll(".category-filter-es");
        const projectItems = document.querySelectorAll(".project-item-es");
        const firstButton = filterButtons[0];
        if (firstButton) {
            firstButton.classList.add("bg-blue-600", "text-white", "border-blue-600");
        }
        filterButtons.forEach((button, index) => {
            if (index > 0) {
                button.classList.add("bg-white", "dark:bg-slate-800", "text-gray-700", "dark:text-gray-300", "border-gray-300", "dark:border-slate-700");
            }
        });
        filterButtons.forEach((button) => {
            button.addEventListener("click", () => {
                const category = button.getAttribute("data-category");
                filterButtons.forEach((btn) => {
                    btn.classList.remove("bg-blue-600", "text-white", "border-blue-600");
                    btn.classList.add("bg-white", "dark:bg-slate-800", "text-gray-700", "dark:text-gray-300", "border-gray-300", "dark:border-slate-700");
                });
                button.classList.add("bg-blue-600", "text-white", "border-blue-600");
                button.classList.remove("bg-white", "dark:bg-slate-800", "text-gray-700", "dark:text-gray-300", "border-gray-300", "dark:border-slate-700");
                projectItems.forEach((item) => {
                    const htmlItem = item as HTMLElement;
                    const itemCategory = htmlItem.getAttribute("data-category");
                    if (category === "Todos" || itemCategory === category) {
                        htmlItem.style.display = "block";
                        setTimeout(() => { htmlItem.style.opacity = "1"; htmlItem.style.transform = "scale(1)"; }, 10);
                    } else {
                        htmlItem.style.opacity = "0";
                        htmlItem.style.transform = "scale(0.95)";
                        setTimeout(() => { htmlItem.style.display = "none"; }, 200);
                    }
                });
            });
        });
        projectItems.forEach((item) => {
            (item as HTMLElement).style.transition = "opacity 0.2s, transform 0.2s";
        });
    });
</script>
