---
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import BeforeAfterSlider from "@/components/projects/BeforeAfterSlider.astro";
import Button from "@/components/ui/Button.astro";

export const getStaticPaths = (async () => {
    const projects = await getCollection("projects");
    return projects.map((project: CollectionEntry<"projects">) => ({
        params: { slug: project.slug },
        props: { project },
    }));
}) satisfies GetStaticPaths;

interface Props {
    project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { Content } = await project.render();
const { title, titleEs, category, location, description, descriptionEs, date, coverImage, beforeImage, afterImage, tags } = project.data;

const displayTitle = titleEs ?? title;
const displayDescription = descriptionEs ?? description;

const formattedDate = new Intl.DateTimeFormat("es-MX", {
    year: "numeric",
    month: "long",
    day: "numeric",
}).format(date);
---

<Layout title={displayTitle} description={displayDescription} type="article" article={true}>
    <article class="container mx-auto px-4 py-16 max-w-4xl">
        <nav class="mb-8 text-sm">
            <ol class="flex items-center gap-2 text-gray-600 dark:text-gray-400">
                <li><a href="/es/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Inicio</a></li>
                <li>/</li>
                <li><a href="/es/proyectos" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Proyectos</a></li>
                <li>/</li>
                <li class="text-gray-900 dark:text-gray-100 font-semibold">{displayTitle}</li>
            </ol>
        </nav>

        <header class="mb-8">
            <div class="flex flex-wrap items-center gap-3 mb-4">
                <span class="bg-blue-600 text-white text-sm font-semibold px-4 py-1.5 rounded-full">{category}</span>
                {tags && tags.map((tag: string) => (<span class="bg-gray-200 text-gray-700 text-sm px-3 py-1 rounded-full">{tag}</span>))}
            </div>
            <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-gray-100 mb-4">{displayTitle}</h1>
            <div class="flex items-center gap-4 text-gray-600 dark:text-gray-400">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    <span>{location}</span>
                </div>
                <span>•</span>
                <time datetime={date.toISOString()}>{formattedDate}</time>
            </div>
        </header>

        {beforeImage && afterImage ? (
            <div class="mb-12"><BeforeAfterSlider beforeImage={beforeImage} afterImage={afterImage} alt={title} /></div>
        ) : (
            <div class="mb-12">
                <Image src={coverImage} alt={`${title} - ${location}`} class="w-full rounded-xl shadow-lg" widths={[768, 1024, 1920]} sizes="(max-width: 768px) 100vw, 1024px" />
            </div>
        )}

        <div class="prose prose-lg max-w-none mb-12">
            <p class="text-xl text-gray-700 dark:text-gray-300 leading-relaxed">{displayDescription}</p>
        </div>
        <div class="prose prose-lg max-w-none mb-12"><Content /></div>

        <div class="bg-gradient-to-br from-blue-600 to-blue-700 dark:from-blue-800 dark:to-blue-900 rounded-2xl p-8 md:p-12 text-center text-white">
            <h2 class="text-3xl font-bold mb-4">¿Tienes un Proyecto Similar?</h2>
            <p class="text-lg mb-8 opacity-90">Obtén un presupuesto gratuito y sin compromiso para tu próximo proyecto.</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <Button href="/es/contacto" variant="secondary" size="lg">Solicitar Presupuesto</Button>
                <Button href="tel:+14805146765" variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-blue-600">Llamar Ahora</Button>
            </div>
        </div>

        <div class="mt-12 text-center">
            <a href="/es/proyectos" class="inline-flex items-center gap-2 text-blue-600 dark:text-blue-400 hover:text-blue-700 font-semibold transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                Ver Todos los Proyectos
            </a>
        </div>
    </article>
</Layout>
