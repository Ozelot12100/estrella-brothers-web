---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import AboutSection from "../components/home/AboutSection.astro";
import Testimonials from "../components/home/Testimonials.astro";
import FAQ from "../components/home/FAQ.astro";
import ScrollReveal from "../components/ui/ScrollReveal.astro";
import ProjectCard from "../components/projects/ProjectCard.astro";
import Button from "../components/ui/Button.astro";
import { siteConfig } from "../config/site";

// Get featured projects
const allProjects = await getCollection("projects");
const featuredProjects = allProjects
	.filter((project: CollectionEntry<"projects">) => project.data.featured)
	.sort(
		(a: CollectionEntry<"projects">, b: CollectionEntry<"projects">) =>
			b.data.date.getTime() - a.data.date.getTime(),
	)
	.slice(0, 3);
---

<Layout title={siteConfig.title} description={siteConfig.description}>
	<ScrollReveal />
	<!-- Hero Section -->
	<section
		class="relative min-h-[90vh] flex items-center justify-center text-white py-24 md:py-32 overflow-hidden"
	>
		<!-- Background Image with Overlay -->
		<div class="absolute inset-0 z-0">
			<img
				src="https://images.unsplash.com/photo-1541888086925-920a0bfaadc8?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80"
				alt="Fondo de construcción"
				class="w-full h-full object-cover"
			/>
			<div
				class="absolute inset-0 bg-gradient-to-r from-gray-900/95 via-gray-900/80 to-gray-800/60 backdrop-blur-[2px]"
			>
			</div>
		</div>

		<div class="container mx-auto px-4 relative z-10">
			<div class="max-w-4xl mx-auto text-center">
				<h1
					class="text-5xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight"
				>
					Carpintería Profesional en <span class="text-blue-400"
						>Phoenix, AZ</span
					>
				</h1>
				<p
					class="text-xl md:text-2xl text-gray-300 mb-8 leading-relaxed"
				>
					Especialistas en Framing, Remodelaciones y Carpintería
					Personalizada. Transformamos espacios con calidad y
					profesionalismo garantizado.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<Button href="/contacto" variant="primary" size="lg">
						Solicitar Presupuesto Gratis
					</Button>
					<Button
						href="/proyectos"
						variant="outline"
						size="lg"
						class="border-white text-white hover:bg-white hover:text-gray-900"
					>
						Ver Proyectos
					</Button>
				</div>

				<!-- Quick Stats -->
				<div
					class="grid grid-cols-3 gap-6 mt-16 pt-16 border-t border-gray-700"
				>
					<div>
						<div class="text-4xl font-bold text-blue-400 mb-2">
							10+
						</div>
						<div class="text-gray-400">Años de Experiencia</div>
					</div>
					<div>
						<div class="text-4xl font-bold text-blue-400 mb-2">
							500+
						</div>
						<div class="text-gray-400">Proyectos Completados</div>
					</div>
					<div>
						<div class="text-4xl font-bold text-blue-400 mb-2">
							100%
						</div>
						<div class="text-gray-400">
							Satisfacción Garantizada
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- About Section -->
	<AboutSection />

	<!-- Services Section -->
	<section class="py-20 bg-gray-50">
		<div class="container mx-auto px-4">
			<div class="text-center mb-16 reveal-on-scroll reveal-fade-up">
				<h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
					Nuestros Servicios
				</h2>
				<p class="text-xl text-gray-600 max-w-2xl mx-auto">
					Ofrecemos una amplia gama de servicios de carpintería y
					remodelación para hogares y negocios.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{
					siteConfig.business.serviceTypes.map((service, index) => {
						const icons = [
							"M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
							"M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z",
							"M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6",
							"M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5",
							"M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01",
						];
						return (
							<div
								class={`bg-white rounded-xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 reveal-on-scroll reveal-fade-up delay-${((index % 3) + 1) * 100}`}
							>
								<div class="bg-blue-600 text-white w-14 h-14 rounded-lg flex items-center justify-center mb-4 shadow-md">
									<svg
										class="w-7 h-7"
										fill="none"
										stroke="currentColor"
										viewBox="0 0 24 24"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d={icons[index % icons.length]}
										/>
									</svg>
								</div>
								<h3 class="text-xl font-bold text-gray-900 mb-2">
									{service}
								</h3>
								<p class="text-gray-600">
									Servicio profesional de{" "}
									{service.toLowerCase()} con atención al
									detalle y acabados de calidad.
								</p>
							</div>
						);
					})
				}
			</div>
		</div>
	</section>

	<!-- Featured Projects Section -->
	{
		featuredProjects.length > 0 && (
			<section class="py-20 bg-white">
				<div class="container mx-auto px-4">
					<div class="text-center mb-16 reveal-on-scroll reveal-fade-up">
						<h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
							Proyectos Destacados
						</h2>
						<p class="text-xl text-gray-600 max-w-2xl mx-auto">
							Conoce algunos de nuestros trabajos más recientes y
							la transformación que logramos.
						</p>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
						{featuredProjects.map(
							(project: CollectionEntry<"projects">, index) => (
								<div
									class={`reveal-on-scroll reveal-fade-up delay-${((index % 3) + 1) * 100}`}
								>
									<ProjectCard project={project} />
								</div>
							),
						)}
					</div>

					<div class="text-center reveal-on-scroll reveal-fade-up delay-400">
						<Button href="/proyectos" variant="primary" size="lg">
							Ver Todos los Proyectos
						</Button>
					</div>
				</div>
			</section>
		)
	}

	<!-- Testimonials Section -->
	<Testimonials />

	<!-- FAQ Section -->
	<FAQ />

	<!-- Call to Action Section -->
	<section class="py-20 bg-blue-600 text-white relative overflow-hidden">
		<!-- Decorative Background -->
		<div class="absolute inset-0 z-0 opacity-10">
			<svg
				class="absolute w-full h-full"
				xmlns="http://www.w3.org/2000/svg"
			>
				<defs>
					<pattern
						id="grid"
						width="40"
						height="40"
						patternUnits="userSpaceOnUse"
					>
						<path
							d="M0 40V0H40V40H0ZM39 39V1H1V39H39Z"
							fill="currentColor"></path>
					</pattern>
				</defs>
				<rect width="100%" height="100%" fill="url(#grid)"></rect>
			</svg>
		</div>

		<div
			class="container mx-auto px-4 text-center relative z-10 reveal-on-scroll reveal-scale"
		>
			<h2 class="text-4xl md:text-5xl font-bold mb-6">
				¿Listo para Comenzar tu Proyecto?
			</h2>
			<p class="text-xl mb-8 max-w-2xl mx-auto opacity-90">
				Obtén un presupuesto gratuito y sin compromiso. Estamos aquí
				para ayudarte a hacer realidad tu visión.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<Button href="/contacto" variant="secondary" size="lg">
					Solicitar Presupuesto
				</Button>
				<Button
					href={`tel:${siteConfig.author.phone}`}
					variant="outline"
					size="lg"
					class="border-white text-white hover:bg-white hover:text-blue-600"
				>
					<svg
						class="w-5 h-5 mr-2"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
						></path>
					</svg>
					{siteConfig.author.phone}
				</Button>
			</div>
		</div>
	</section>

	<!-- Service Areas Section -->
	<section class="py-16 bg-gray-50">
		<div
			class="container mx-auto px-4 text-center reveal-on-scroll reveal-fade-up"
		>
			<h3 class="text-2xl font-bold text-gray-900 mb-6">
				Servimos el Área Metropolitana de Phoenix
			</h3>
			<div class="flex flex-wrap justify-center gap-4">
				{
					siteConfig.business.areaServed.map((area) => (
						<span class="bg-gray-100 text-gray-700 px-6 py-2 rounded-full font-medium">
							{area}
						</span>
					))
				}
			</div>
		</div>
	</section>
</Layout>
