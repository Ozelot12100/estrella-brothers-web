---
import Layout from "@/layouts/Layout.astro";
import Button from "@/components/ui/Button.astro";
import { ui } from "@/i18n/ui";
import { localizePath } from "@/i18n/routes";

// Vercel estático sirve /404.html para cualquier ruta inexistente (incl. /es/*),
// así que renderizamos ambos idiomas y un script muestra el que corresponde.
const langs = ["en", "es"] as const;
---

<Layout
    title={ui.en["notfound.seoTitle"]}
    description={ui.en["notfound.seoDescription"]}
    noindex={true}
>
    <div class="min-h-[70vh] flex flex-col items-center justify-center px-4 py-16 text-center">
        {
            langs.map((code) => (
                <div data-lang-block={code} class={code === "es" ? "hidden" : ""}>
                    <p class="font-serif text-8xl md:text-9xl font-bold text-primary/20 tracking-tight">404</p>
                    <h1 class="mt-2 font-serif text-3xl md:text-4xl font-bold text-primary">
                        {ui[code]["notfound.title"]}
                    </h1>
                    <p class="mt-4 text-lg text-on-surface-variant max-w-md mx-auto">
                        {ui[code]["notfound.message"]}
                    </p>
                    <div class="mt-8 flex flex-col sm:flex-row gap-4 items-center justify-center">
                        <Button href={localizePath("home", code)} variant="primary">
                            {ui[code]["notfound.home"]}
                        </Button>
                        <Button href={localizePath("contact", code)} variant="outline">
                            {ui[code]["notfound.contact"]}
                        </Button>
                    </div>
                </div>
            ))
        }
    </div>
</Layout>

<script is:inline>
    if (location.pathname === "/es" || location.pathname.startsWith("/es/")) {
        document.documentElement.lang = "es";
        document.querySelectorAll("[data-lang-block]").forEach((el) => {
            el.classList.toggle(
                "hidden",
                el.getAttribute("data-lang-block") !== "es",
            );
        });
    }
</script>
