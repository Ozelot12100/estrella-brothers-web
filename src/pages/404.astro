---
import Layout from "@/layouts/Layout.astro";
import Button from "@/components/ui/Button.astro";
import { ui } from "@/i18n/ui";
import { localizePath } from "@/i18n/routes";

// Vercel estático sirve /404.html para CUALQUIER ruta inexistente (incluidas /es/*),
// así que esta página renderiza ambos idiomas y un script muestra el que corresponde.
const langs = ["en", "es"] as const;
---

<Layout
    title={ui.en["notfound.seoTitle"]}
    description={ui.en["notfound.seoDescription"]}
    noindex={true}
>
    <div
        class="min-h-[70vh] flex flex-col items-center justify-center px-4 text-center bg-gray-50 dark:bg-slate-900 transition-colors duration-300"
    >
        {
            langs.map((code) => (
                <div
                    data-lang-block={code}
                    class={code === "es" ? "hidden" : ""}
                >
                    <div class="mb-8">
                        <h1 class="text-9xl font-extrabold text-blue-700 dark:text-blue-500 tracking-tight">
                            404
                        </h1>
                        <h2 class="mt-4 text-3xl font-bold text-gray-900 dark:text-gray-100 sm:text-4xl">
                            {ui[code]["notfound.title"]}
                        </h2>
                        <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 max-w-md mx-auto">
                            {ui[code]["notfound.message"]}
                        </p>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-4 items-center justify-center">
                        <Button
                            href={localizePath("home", code)}
                            variant="primary"
                            class="gap-2"
                        >
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
                                />
                            </svg>
                            {ui[code]["notfound.home"]}
                        </Button>
                        <Button
                            href={localizePath("contact", code)}
                            variant="outline"
                        >
                            {ui[code]["notfound.contact"]}
                        </Button>
                    </div>
                </div>
            ))
        }
    </div>
</Layout>

<script is:inline>
    if (
        location.pathname === "/es" ||
        location.pathname.startsWith("/es/")
    ) {
        document.documentElement.lang = "es";
        document.querySelectorAll("[data-lang-block]").forEach((el) => {
            el.classList.toggle(
                "hidden",
                el.getAttribute("data-lang-block") !== "es",
            );
        });
    }
</script>
