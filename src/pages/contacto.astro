---
import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.astro";
import { siteConfig } from "../config/site";
---

<Layout
    title="Contacto"
    description={`Contacta a ${siteConfig.name} para servicios de carpintería y remodelaciones en Phoenix, AZ. Presupuestos gratuitos.`}
>
    <div class="container mx-auto px-4 py-16">
        <!-- Header -->
        <div class="text-center mb-12">
            <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
                Solicita tu Presupuesto
            </h1>
            <p class="text-xl text-gray-600 max-w-2xl mx-auto">
                Estamos listos para transformar tu proyecto en realidad.
                Contáctanos hoy mismo.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
            <!-- Contact Form -->
            <div class="bg-white rounded-2xl shadow-lg p-8">
                <h2 class="text-2xl font-bold text-gray-900 mb-6">
                    Envíanos un Mensaje
                </h2>

                <form
                    id="contact-form"
                    class="space-y-6"
                    data-netlify="true"
                    name="contact"
                >
                    <input type="hidden" name="form-name" value="contact" />

                    <div>
                        <label
                            for="name"
                            class="block text-sm font-semibold text-gray-700 mb-2"
                        >
                            Nombre Completo
                        </label>
                        <input
                            type="text"
                            id="name"
                            name="name"
                            required
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                            placeholder="Juan Pérez"
                        />
                    </div>

                    <div>
                        <label
                            for="phone"
                            class="block text-sm font-semibold text-gray-700 mb-2"
                        >
                            Teléfono
                        </label>
                        <input
                            type="tel"
                            id="phone"
                            name="phone"
                            required
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                            placeholder="(480) 000-0000"
                        />
                    </div>

                    <div>
                        <label
                            for="email"
                            class="block text-sm font-semibold text-gray-700 mb-2"
                        >
                            Email
                        </label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                            placeholder="ejemplo@email.com"
                        />
                    </div>

                    <div>
                        <label
                            for="service"
                            class="block text-sm font-semibold text-gray-700 mb-2"
                        >
                            Tipo de Servicio
                        </label>
                        <select
                            id="service"
                            name="service"
                            required
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                        >
                            <option value="">Selecciona un servicio</option>
                            {
                                siteConfig.business.serviceTypes.map(
                                    (service) => (
                                        <option value={service}>
                                            {service}
                                        </option>
                                    ),
                                )
                            }
                        </select>
                    </div>

                    <div>
                        <label
                            for="message"
                            class="block text-sm font-semibold text-gray-700 mb-2"
                        >
                            Mensaje
                        </label>
                        <textarea
                            id="message"
                            name="message"
                            rows="4"
                            required
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none"
                            placeholder="Cuéntanos sobre tu proyecto..."
                        ></textarea>
                    </div>

                    <Button
                        type="submit"
                        variant="primary"
                        size="lg"
                        class="w-full relative overflow-hidden group"
                        id="submit-btn"
                    >
                        <span id="btn-text">Enviar Mensaje</span>
                        <div
                            id="btn-spinner"
                            class="absolute inset-0 flex items-center justify-center bg-blue-700 opacity-0 hidden"
                        >
                            <svg
                                class="animate-spin h-5 w-5 text-white"
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                            >
                                <circle
                                    class="opacity-25"
                                    cx="12"
                                    cy="12"
                                    r="10"
                                    stroke="currentColor"
                                    stroke-width="4"></circle>
                                <path
                                    class="opacity-75"
                                    fill="currentColor"
                                    d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                                ></path>
                            </svg>
                        </div>
                    </Button>

                    <!-- Form Messages -->
                    <div
                        id="form-success"
                        class="hidden p-4 mb-4 text-sm text-green-800 rounded-lg bg-green-50"
                        role="alert"
                    >
                        ¡Mensaje enviado con éxito! Nos pondremos en contacto
                        contigo pronto.
                    </div>
                    <div
                        id="form-error"
                        class="hidden p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50"
                        role="alert"
                    >
                        Hubo un error al enviar el mensaje. Por favor, inténtalo
                        de nuevo o contáctanos por teléfono.
                    </div>
                </form>
            </div>

            <!-- Contact Info -->
            <div class="space-y-8">
                <!-- Phone -->
                <div class="bg-blue-50 rounded-2xl p-8">
                    <div class="flex items-start gap-4">
                        <div class="bg-blue-600 text-white p-3 rounded-lg">
                            <svg
                                class="w-6 h-6"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-bold text-gray-900 mb-2">
                                Llámanos
                            </h3>
                            <a
                                href={`tel:${siteConfig.author.phone}`}
                                class="text-lg text-blue-600 hover:text-blue-700 font-semibold"
                            >
                                {siteConfig.author.phone}
                            </a>
                            <p class="text-sm text-gray-600 mt-1">
                                Lunes a Sábado: 7am - 6pm
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Email -->
                <div class="bg-gray-50 rounded-2xl p-8">
                    <div class="flex items-start gap-4">
                        <div class="bg-gray-800 text-white p-3 rounded-lg">
                            <svg
                                class="w-6 h-6"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-bold text-gray-900 mb-2">Email</h3>
                            <a
                                href={`mailto:${siteConfig.author.email}`}
                                class="text-lg text-gray-700 hover:text-blue-600"
                            >
                                {siteConfig.author.email}
                            </a>
                            <p class="text-sm text-gray-600 mt-1">
                                Respuesta en 24 horas
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Service Area -->
                <div class="bg-green-50 rounded-2xl p-8">
                    <div class="flex items-start gap-4">
                        <div class="bg-green-600 text-white p-3 rounded-lg">
                            <svg
                                class="w-6 h-6"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                ></path>
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-bold text-gray-900 mb-2">
                                Área de Servicio
                            </h3>
                            <p class="text-gray-700">
                                {siteConfig.business.areaServed.join(", ")}
                            </p>
                            <p class="text-sm text-gray-600 mt-1">
                                Greater Phoenix Area
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const form = document.getElementById("contact-form") as HTMLFormElement;
        const submitBtn = document.getElementById(
            "submit-btn",
        ) as HTMLButtonElement;
        const btnText = document.getElementById("btn-text");
        const btnSpinner = document.getElementById("btn-spinner");
        const formSuccess = document.getElementById("form-success");
        const formError = document.getElementById("form-error");

        if (form) {
            form.addEventListener("submit", async (e) => {
                e.preventDefault();

                // Hide previous messages
                formSuccess?.classList.add("hidden");
                formError?.classList.add("hidden");

                // Show loading state
                if (submitBtn && btnText && btnSpinner) {
                    submitBtn.disabled = true;
                    btnText.classList.add("opacity-0");
                    btnSpinner.classList.remove("hidden");
                    btnSpinner.classList.replace("opacity-0", "opacity-100");
                }

                try {
                    const formData = new FormData(form);
                    const response = await fetch("/", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/x-www-form-urlencoded",
                        },
                        body: new URLSearchParams(formData as any).toString(),
                    });

                    if (response.ok) {
                        formSuccess?.classList.remove("hidden");
                        form.reset();
                    } else {
                        formError?.classList.remove("hidden");
                    }
                } catch (error) {
                    console.error("Submission error:", error);
                    formError?.classList.remove("hidden");
                } finally {
                    // Reset button state
                    if (submitBtn && btnText && btnSpinner) {
                        submitBtn.disabled = false;
                        btnText.classList.remove("opacity-0");
                        btnSpinner.classList.add("hidden");
                        btnSpinner.classList.replace(
                            "opacity-100",
                            "opacity-0",
                        );
                    }
                }
            });
        }
    });
</script>
