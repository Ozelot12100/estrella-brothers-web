---
import Layout from "@/layouts/Layout.astro";
import Button from "@/components/ui/Button.astro";
import { siteConfig } from "@/config/site";
---

<Layout
    title="Contact"
    description={`Contact ${siteConfig.name} for carpentry and remodeling services in Phoenix, AZ. Free estimates.`}
>
    <div class="container mx-auto px-4 py-16">
        <!-- Header -->
        <div class="text-center mb-12">
            <h1
                class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-gray-100 mb-4"
            >
                Request Your Estimate
            </h1>
            <p
                class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto"
            >
                We are ready to transform your project into reality. Contact us
                today.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
            <!-- Contact Form -->
            <div
                class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg p-8 transition-colors duration-300"
            >
                <h2
                    class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6"
                >
                    Send us a Message
                </h2>

                <form id="contact-form" class="space-y-6">
                    <div>
                        <label
                            for="name"
                            class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"
                        >
                            Full Name
                        </label>
                        <input
                            type="text"
                            id="name"
                            name="name"
                            required
                            class="w-full px-4 py-3 border border-gray-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
                            placeholder="John Doe"
                        />
                    </div>

                    <div>
                        <label
                            for="phone"
                            class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"
                        >
                            Phone
                        </label>
                        <input
                            type="tel"
                            id="phone"
                            name="phone"
                            required
                            class="w-full px-4 py-3 border border-gray-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
                            placeholder="(480) 000-0000"
                        />
                    </div>

                    <div>
                        <label
                            for="email"
                            class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"
                        >
                            Email
                        </label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            class="w-full px-4 py-3 border border-gray-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
                            placeholder="example@email.com"
                        />
                    </div>

                    <div>
                        <label
                            for="service"
                            class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"
                        >
                            Type of Service
                        </label>
                        <select
                            id="service"
                            name="service"
                            required
                            class="w-full px-4 py-3 border border-gray-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
                        >
                            <option value="">Select a service</option>
                            {
                                siteConfig.business.serviceTypes.map(
                                    (service) => (
                                        <option value={service}>
                                            {service}
                                        </option>
                                    ),
                                )
                            }
                        </select>
                    </div>

                    <div>
                        <label
                            for="message"
                            class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"
                        >
                            Message
                        </label>
                        <textarea
                            id="message"
                            name="message"
                            rows="4"
                            required
                            class="w-full px-4 py-3 border border-gray-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none transition-colors"
                            placeholder="Tell us about your project..."></textarea>
                    </div>

                    <Button
                        type="submit"
                        variant="primary"
                        size="lg"
                        class="w-full relative overflow-hidden group"
                        id="submit-btn"
                    >
                        <span id="btn-text">Send Message via WhatsApp</span>
                    </Button>

                    <!-- Form Messages -->
                    <div
                        id="form-success"
                        class="hidden p-4 mb-4 text-sm text-green-800 dark:text-green-200 rounded-lg bg-green-50 dark:bg-green-900/30"
                        role="alert"
                    >
                        Message sent! We will get in touch with you shortly via
                        WhatsApp.
                    </div>
                </form>
            </div>

            <!-- Contact Info -->
            <div class="space-y-8">
                <!-- Phone -->
                <div
                    class="bg-blue-50 dark:bg-blue-900/20 rounded-2xl p-8 transition-colors duration-300"
                >
                    <div class="flex items-start gap-4">
                        <div class="bg-blue-600 text-white p-3 rounded-lg">
                            <svg
                                class="w-6 h-6"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h3
                                class="font-bold text-gray-900 dark:text-gray-100 mb-2"
                            >
                                Call Us
                            </h3>
                            <a
                                href={`tel:${siteConfig.author.phone}`}
                                class="text-lg text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-semibold transition-colors"
                            >
                                {siteConfig.author.phone}
                            </a>
                            <p
                                class="text-sm text-gray-600 dark:text-gray-400 mt-1"
                            >
                                Monday to Saturday: 7am - 6pm
                            </p>
                        </div>
                    </div>
                </div>

                <!-- WhatsApp -->
                <div
                    class="bg-green-50 dark:bg-green-900/20 rounded-2xl p-8 transition-colors duration-300"
                >
                    <div class="flex items-start gap-4">
                        <div class="bg-green-600 text-white p-3 rounded-lg">
                            <svg
                                class="w-6 h-6"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h3
                                class="font-bold text-gray-900 dark:text-gray-100 mb-2"
                            >
                                WhatsApp
                            </h3>
                            <a
                                href="https://wa.me/14805146765"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-lg text-green-600 dark:text-green-400 hover:text-green-700 font-semibold transition-colors"
                            >
                                {siteConfig.author.phone}
                            </a>
                            <p
                                class="text-sm text-gray-600 dark:text-gray-400 mt-1"
                            >
                                Fastest way to reach us
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Service Area -->
                <div
                    class="bg-gray-50 dark:bg-slate-800 rounded-2xl p-8 transition-colors duration-300"
                >
                    <div class="flex items-start gap-4">
                        <div class="bg-gray-800 text-white p-3 rounded-lg">
                            <svg
                                class="w-6 h-6"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                ></path>
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                        </div>
                        <div>
                            <h3
                                class="font-bold text-gray-900 dark:text-gray-100 mb-2"
                            >
                                Service Area
                            </h3>
                            <p class="text-gray-700 dark:text-gray-300">
                                {siteConfig.business.areaServed.join(", ")}
                            </p>
                            <p
                                class="text-sm text-gray-600 dark:text-gray-400 mt-1"
                            >
                                Greater Phoenix Area
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const form = document.getElementById("contact-form") as HTMLFormElement;
        const formSuccess = document.getElementById("form-success");

        if (form) {
            form.addEventListener("submit", (e) => {
                e.preventDefault();

                const formData = new FormData(form);
                const object = Object.fromEntries(formData);

                const phone = "14805146765";
                const whatsappMessage = `Hello, my name is ${object.name}.\n\nI am interested in a ${object.service} service.\n\nMy phone number is ${object.phone} and my email is ${object.email}.\n\nMessage:\n${object.message}`;

                const encodedMessage = encodeURIComponent(whatsappMessage);
                const whatsappUrl = `https://wa.me/${phone}?text=${encodedMessage}`;

                window.open(whatsappUrl, "_blank");

                formSuccess?.classList.remove("hidden");
                form.reset();
            });
        }
    });
</script>
