---
import "@fontsource-variable/source-serif-4";
import "@fontsource-variable/work-sans";
import "../styles/global.css";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";
import SEOHead from "../components/common/SEOHead.astro";
import WhatsAppButton from "../components/ui/WhatsAppButton.astro";
import MobileBar from "../components/common/MobileBar.astro";
import type { SEOProps } from "../types";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

interface Props extends SEOProps {}

const seo = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
    <head>
        <SEOHead {...seo} />
    </head>
    <body class="min-h-screen flex flex-col antialiased pb-16 md:pb-0">
        <div class="grain-overlay" aria-hidden="true"></div>
        <a
            href="#main-content"
            class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-primary-container focus:text-on-primary focus:px-4 focus:py-2 focus:rounded"
        >
            {t("a11y.skip")}
        </a>
        <Header />
        <main id="main-content" class="flex-1 relative z-[2]">
            <slot />
        </main>
        <Footer />
        <WhatsAppButton />
        <MobileBar />

        {
            import.meta.env.PROD && (
                <>
                    <script is:inline defer src="/_vercel/insights/script.js" />
                    <script is:inline defer src="/_vercel/speed-insights/script.js" />
                </>
            )
        }
    </body>
</html>
