---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import AboutSection from "@/components/home/AboutSection.astro";
import Testimonials from "@/components/home/Testimonials.astro";
import FAQ from "@/components/home/FAQ.astro";
import ScrollReveal from "@/components/ui/ScrollReveal.astro";
import ProjectCard from "@/components/projects/ProjectCard.astro";
import Button from "@/components/ui/Button.astro";
import { siteConfig } from "@/config/site";
import type { ServiceKey } from "@/types";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { localizePath } from "@/i18n/routes";

import heroImg from "@/assets/projects/framing-01.webp";
import framingImg from "@/assets/projects/framing-01.webp";
import interiorImg from "@/assets/projects/interior-01.webp";
import decksImg from "@/assets/projects/decks-01.webp";
import carpentryImg from "@/assets/projects/carpentry-01.webp";
import baseboardsImg from "@/assets/projects/baseboards-01.webp";
import woodrotImg from "@/assets/projects/woodrot-01.webp";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const serviceImages: Record<ServiceKey, ImageMetadata> = {
	framing: framingImg,
	remodeling: interiorImg,
	decks: decksImg,
	carpentry: carpentryImg,
	finishes: baseboardsImg,
	woodrot: woodrotImg,
};

const allProjects = await getCollection("projects");
const featuredProjects = allProjects
	.filter((p: CollectionEntry<"projects">) => p.data.featured)
	.sort(
		(a: CollectionEntry<"projects">, b: CollectionEntry<"projects">) =>
			b.data.date.getTime() - a.data.date.getTime(),
	)
	.slice(0, 3);
---

<Layout title={t("home.seoTitle")} description={t("home.seoDescription")}>
	<ScrollReveal />

	<!-- Hero -->
	<section class="relative overflow-hidden bg-surface-container">
		<div class="absolute inset-0">
			<Image
				src={heroImg}
				alt=""
				class="w-full h-full object-cover object-right"
				widths={[768, 1280, 1920]}
				sizes="100vw"
				loading="eager"
				fetchpriority="high"
			/>
			<div
				class="absolute inset-0 bg-gradient-to-r from-surface via-surface/90 md:via-surface/75 to-surface/40 md:to-transparent"
			>
			</div>
		</div>

		<div class="relative max-w-7xl mx-auto px-4 md:px-16 py-24 md:py-36">
			<div class="max-w-2xl">
				<p class="label-caps text-xs text-secondary mb-6">
					100+ {t("stats.projects")} · {t("stats.years")}
				</p>
				<h1
					class="font-serif text-4xl md:text-6xl font-bold text-primary leading-tight tracking-tight mb-6"
				>
					{t("hero.title")}
					{t("hero.titleHighlight")}
				</h1>
				<p
					class="text-lg md:text-xl text-on-surface-variant leading-relaxed mb-10 max-w-xl border-l-2 border-primary/30 pl-4"
				>
					{t("hero.subtitle")}
				</p>
				<div class="flex flex-wrap gap-4">
					<Button href={localizePath("contact", lang)} variant="primary" size="lg">
						{t("hero.cta")}
					</Button>
					<Button href={localizePath("projects", lang)} variant="outline" size="lg">
						{t("hero.cta2")}
					</Button>
				</div>
			</div>
		</div>
	</section>

	<!-- Servicios -->
	<section id="services" class="max-w-7xl mx-auto px-4 md:px-16 py-20 md:py-28">
		<div class="mb-14 reveal-on-scroll reveal-fade-up">
			<h2 class="font-serif text-3xl md:text-4xl font-semibold text-primary mb-4">
				{t("services.title")}
			</h2>
			<div class="w-24 h-1 bg-outline-variant/60"></div>
			<p class="mt-4 text-on-surface-variant max-w-2xl">{t("services.subtitle")}</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2">
			{
				siteConfig.business.serviceTypes.map((service, index) => {
					const serviceName = t(`service.${service}`);
					return (
						<a
							href={localizePath("contact", lang)}
							class={`group block bg-surface-low border border-outline-variant/40 rounded overflow-hidden hover:border-outline transition-colors reveal-on-scroll reveal-fade-up delay-${((index % 3) + 1) * 100}`}
						>
							<div class="h-48 overflow-hidden">
								<img
									src={serviceImages[service].src}
									alt={serviceName}
									class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
									loading="lazy"
								/>
							</div>
							<div class="p-6">
								<h3 class="font-serif text-xl font-semibold text-primary mb-2">
									{serviceName}
								</h3>
								<p class="text-sm text-on-surface-variant leading-relaxed">
									{t("services.descPrefix")}
									{serviceName.toLowerCase()}
									{t("services.descSuffix")}
								</p>
								<span class="inline-flex items-center gap-1 mt-4 label-caps text-xs text-secondary group-hover:text-primary transition-colors">
									{t("services.requestEstimate")}
									<svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
								</span>
							</div>
						</a>
					);
				})
			}
		</div>
	</section>

	<!-- Sobre nosotros / calidad -->
	<AboutSection />

	<!-- Proyectos destacados -->
	{
		featuredProjects.length > 0 && (
			<section class="max-w-7xl mx-auto px-4 md:px-16 py-20 md:py-28">
				<div class="flex flex-wrap items-end justify-between gap-4 mb-14 reveal-on-scroll reveal-fade-up">
					<div>
						<h2 class="font-serif text-3xl md:text-4xl font-semibold text-primary mb-4">
							{t("featured.title")}
						</h2>
						<div class="w-24 h-1 bg-outline-variant/60" />
					</div>
					<a
						href={localizePath("projects", lang)}
						class="label-caps text-xs text-secondary hover:text-primary transition-colors"
					>
						{t("featured.viewAll")}
					</a>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2">
					{featuredProjects.map((project: CollectionEntry<"projects">, index) => (
						<div class={`reveal-on-scroll reveal-fade-up delay-${((index % 3) + 1) * 100}`}>
							<ProjectCard project={project} />
						</div>
					))}
				</div>
			</section>
		)
	}

	<!-- Testimonios -->
	<Testimonials />

	<!-- FAQ -->
	<FAQ />

	<!-- CTA final -->
	<section class="bg-primary text-on-primary">
		<div class="max-w-4xl mx-auto px-4 md:px-16 py-20 md:py-28 text-center reveal-on-scroll reveal-scale">
			<h2 class="font-serif text-3xl md:text-5xl font-bold mb-6">
				{t("cta.title")}
			</h2>
			<p class="text-lg opacity-80 mb-10 max-w-2xl mx-auto">{t("cta.subtitle")}</p>
			<div class="flex flex-wrap gap-4 justify-center">
				<Button
					href={localizePath("contact", lang)}
					variant="outline"
					size="lg"
					class="!border-on-primary/40 !text-on-primary !bg-transparent hover:!bg-on-primary hover:!text-primary"
				>
					{t("cta.button")}
				</Button>
				<Button
					href={`tel:${siteConfig.author.phone.e164}`}
					variant="outline"
					size="lg"
					class="!border-on-primary/40 !text-on-primary !bg-transparent hover:!bg-on-primary hover:!text-primary"
				>
					{siteConfig.author.phone.display}
				</Button>
			</div>
		</div>
	</section>

	<!-- Áreas de servicio -->
	<section class="max-w-7xl mx-auto px-4 md:px-16 py-16 text-center reveal-on-scroll reveal-fade-up">
		<h3 class="font-serif text-2xl font-semibold text-primary mb-6">{t("areas.title")}</h3>
		<div class="flex flex-wrap justify-center gap-3">
			{
				siteConfig.business.areaServed.map((area) => (
					<span class="bg-secondary-container text-on-secondary-container px-5 py-2 rounded label-caps text-xs">
						{area}
					</span>
				))
			}
		</div>
	</section>
</Layout>
