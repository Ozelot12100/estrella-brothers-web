---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import ProjectCard from "@/components/projects/ProjectCard.astro";
import Button from "@/components/ui/Button.astro";
import { siteConfig } from "@/config/site";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { localizePath } from "@/i18n/routes";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allProjects = await getCollection("projects");
const projects = allProjects.sort(
    (a: CollectionEntry<"projects">, b: CollectionEntry<"projects">) =>
        b.data.date.getTime() - a.data.date.getTime(),
);

const categories = [
    ...new Set(projects.map((p: CollectionEntry<"projects">) => p.data.category)),
];
---

<Layout title={t("projects.seoTitle")} description={t("projects.seoDescription")}>
    <div class="max-w-7xl mx-auto px-4 md:px-16 py-16 md:py-24">
        <!-- Encabezado -->
        <div class="max-w-3xl mb-12">
            <p class="label-caps text-xs text-secondary mb-4">{t("nav.projects")}</p>
            <h1 class="font-serif text-4xl md:text-5xl font-bold text-primary mb-4">
                {t("projects.title")}
            </h1>
            <div class="w-24 h-1 bg-outline-variant/60"></div>
            <p class="mt-4 text-lg text-on-surface-variant">{t("projects.subtitle")}</p>
        </div>

        <!-- Filtro por categoría -->
        <div class="flex flex-wrap gap-2 mb-12">
            <button
                class="category-filter active label-caps text-xs px-5 py-2 rounded border border-outline-variant/60 text-on-surface-variant hover:border-outline transition-colors"
                data-category="All"
            >
                {t("projects.filterAll")}
            </button>
            {
                categories.map((category) => (
                    <button
                        class="category-filter label-caps text-xs px-5 py-2 rounded border border-outline-variant/60 text-on-surface-variant hover:border-outline transition-colors"
                        data-category={category}
                    >
                        {t(`category.${category}`)}
                    </button>
                ))
            }
        </div>

        <!-- Grid -->
        {
            projects.length > 0 ? (
                <div
                    id="projects-grid"
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2"
                >
                    {projects.map((project: CollectionEntry<"projects">) => (
                        <div class="project-item" data-category={project.data.category}>
                            <ProjectCard project={project} />
                        </div>
                    ))}
                </div>
            ) : (
                <div class="text-center py-16">
                    <p class="text-on-surface-variant text-lg">{t("projects.empty")}</p>
                </div>
            )
        }
    </div>

    <!-- CTA -->
    <section class="bg-surface-container border-t border-outline-variant/30">
        <div class="max-w-4xl mx-auto px-4 md:px-16 py-16 md:py-24 text-center">
            <h2 class="font-serif text-3xl md:text-4xl font-semibold text-primary mb-4">
                {t("cta.title")}
            </h2>
            <p class="text-on-surface-variant mb-8 max-w-2xl mx-auto">{t("cta.subtitle")}</p>
            <div class="flex flex-wrap gap-4 justify-center">
                <Button href={localizePath("contact", lang)} variant="primary" size="lg">
                    {t("cta.button")}
                </Button>
                <Button href={`tel:${siteConfig.author.phone.e164}`} variant="outline" size="lg">
                    {siteConfig.author.phone.display}
                </Button>
            </div>
        </div>
    </section>
</Layout>

<style>
    button.category-filter.active {
        background-color: var(--color-primary-container);
        border-color: var(--color-primary-container);
        color: var(--color-on-primary);
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const filterButtons =
            document.querySelectorAll<HTMLButtonElement>(".category-filter");
        const projectItems =
            document.querySelectorAll<HTMLElement>(".project-item");

        projectItems.forEach((item) => {
            item.style.transition = "opacity 0.2s, transform 0.2s";
        });

        filterButtons.forEach((button) => {
            button.addEventListener("click", () => {
                const category = button.getAttribute("data-category");
                filterButtons.forEach((btn) => btn.classList.remove("active"));
                button.classList.add("active");

                projectItems.forEach((item) => {
                    const itemCategory = item.getAttribute("data-category");
                    if (category === "All" || itemCategory === category) {
                        item.style.display = "block";
                        setTimeout(() => {
                            item.style.opacity = "1";
                            item.style.transform = "scale(1)";
                        }, 10);
                    } else {
                        item.style.opacity = "0";
                        item.style.transform = "scale(0.95)";
                        setTimeout(() => {
                            item.style.display = "none";
                        }, 200);
                    }
                });
            });
        });
    });
</script>
