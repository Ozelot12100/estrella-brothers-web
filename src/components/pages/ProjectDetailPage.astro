---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import BeforeAfterSlider from "@/components/projects/BeforeAfterSlider.astro";
import Button from "@/components/ui/Button.astro";
import { siteConfig } from "@/config/site";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { localizePath } from "@/i18n/routes";

interface Props {
    project: CollectionEntry<"projects">;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { project } = Astro.props;
const { Content } = await render(project);
const {
    title,
    titleEs,
    category,
    location,
    description,
    descriptionEs,
    date,
    coverImage,
    beforeImage,
    afterImage,
    tags,
} = project.data;

const displayTitle = lang === "es" ? (titleEs ?? title) : title;
const displayDescription =
    lang === "es" ? (descriptionEs ?? description) : description;

const formattedDate = new Intl.DateTimeFormat(
    lang === "es" ? "es-MX" : "en-US",
    { year: "numeric", month: "long", day: "numeric" },
).format(date);
---

<Layout title={displayTitle} description={displayDescription} type="article" article={true}>
    <article class="max-w-4xl mx-auto px-4 md:px-16 py-14 md:py-20">
        <!-- Breadcrumb -->
        <nav class="mb-8 text-sm" aria-label="Breadcrumb">
            <ol class="flex items-center gap-2 text-on-surface-variant">
                <li><a href={localizePath("home", lang)} class="hover:text-primary transition-colors">{t("detail.home")}</a></li>
                <li aria-hidden="true">/</li>
                <li><a href={localizePath("projects", lang)} class="hover:text-primary transition-colors">{t("detail.projects")}</a></li>
                <li aria-hidden="true">/</li>
                <li class="text-primary font-semibold">{displayTitle}</li>
            </ol>
        </nav>

        <!-- Encabezado -->
        <header class="mb-8">
            <div class="flex flex-wrap items-center gap-2 mb-4">
                <span class="bg-primary-container text-on-primary label-caps text-xs px-4 py-1.5 rounded">
                    {t(`category.${category}`)}
                </span>
                {
                    tags &&
                        tags.map((tag: string) => (
                            <span class="bg-secondary-container text-on-secondary-container label-caps text-[11px] px-3 py-1 rounded">
                                {tag}
                            </span>
                        ))
                }
            </div>
            <h1 class="font-serif text-4xl md:text-5xl font-bold text-primary mb-4">
                {displayTitle}
            </h1>
            <div class="flex items-center gap-3 text-on-surface-variant text-sm">
                <span>{location}</span>
                <span aria-hidden="true">·</span>
                <time datetime={date.toISOString()}>{formattedDate}</time>
            </div>
        </header>

        <!-- Antes/después o portada -->
        {
            beforeImage && afterImage ? (
                <div class="mb-12">
                    <BeforeAfterSlider beforeImage={beforeImage} afterImage={afterImage} alt={displayTitle} />
                </div>
            ) : (
                <div class="mb-12 rounded overflow-hidden border border-outline-variant/40">
                    <Image
                        src={coverImage}
                        alt={`${displayTitle} - ${location}`}
                        class="w-full"
                        widths={[768, 1024, 1920]}
                        sizes="(max-width: 768px) 100vw, 1024px"
                    />
                </div>
            )
        }

        <!-- Descripción -->
        <p class="font-serif text-xl md:text-2xl text-on-surface leading-relaxed mb-10">
            {displayDescription}
        </p>

        <!-- Contenido markdown -->
        <div class="prose prose-lg max-w-none prose-headings:font-serif prose-headings:text-primary prose-a:text-secondary mb-12">
            <Content />
        </div>

        <!-- CTA -->
        <div class="bg-primary text-on-primary rounded p-8 md:p-12 text-center">
            <h2 class="font-serif text-2xl md:text-3xl font-bold mb-4">{t("detail.ctaTitle")}</h2>
            <p class="opacity-80 mb-8">{t("detail.ctaSubtitle")}</p>
            <div class="flex flex-wrap gap-4 justify-center">
                <Button
                    href={localizePath("contact", lang)}
                    variant="outline"
                    size="lg"
                    class="!border-on-primary/40 !text-on-primary !bg-transparent hover:!bg-on-primary hover:!text-primary"
                >
                    {t("detail.ctaButton")}
                </Button>
                <Button
                    href={`tel:${siteConfig.author.phone.e164}`}
                    variant="outline"
                    size="lg"
                    class="!border-on-primary/40 !text-on-primary !bg-transparent hover:!bg-on-primary hover:!text-primary"
                >
                    {t("nav.callNow")}
                </Button>
            </div>
        </div>

        <!-- Volver -->
        <div class="mt-10 text-center">
            <a
                href={localizePath("projects", lang)}
                class="inline-flex items-center gap-2 label-caps text-xs text-secondary hover:text-primary transition-colors"
            >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                {t("detail.backToProjects")}
            </a>
        </div>
    </article>
</Layout>
