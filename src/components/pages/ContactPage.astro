---
import Layout from "@/layouts/Layout.astro";
import { siteConfig } from "@/config/site";
import { waLink } from "@/utils/contact";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const whatsappUrl = waLink();
const services = siteConfig.business.serviceTypes;
---

<Layout title={t("contact.seoTitle")} description={t("contact.seoDescription")}>
    <div class="max-w-7xl mx-auto px-4 md:px-16 py-14 md:py-20">
        <!-- Hero -->
        <div class="max-w-2xl mb-12">
            <h1 class="font-serif text-4xl md:text-5xl font-bold text-primary mb-4">
                {t("contact.heading")}
            </h1>
            <p class="text-lg text-on-surface-variant leading-relaxed">
                {t("contact.subheading")}
            </p>
        </div>

        <!-- Canales directos -->
        <div class="grid sm:grid-cols-2 gap-3 max-w-2xl mb-14">
            <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-3 bg-whatsapp hover:bg-whatsapp-dark text-white font-semibold px-6 py-4 rounded transition-colors"
            >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"></path></svg>
                {t("contact.waTitle")}
            </a>
            <a
                href={`tel:${siteConfig.author.phone.e164}`}
                class="flex items-center justify-center gap-3 border border-outline text-on-surface bg-surface hover:bg-surface-high font-semibold px-6 py-4 rounded transition-colors"
            >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                {siteConfig.author.phone.display}
            </a>
        </div>

        <!-- Dos columnas: formulario + info -->
        <div class="grid lg:grid-cols-5 gap-10">
            <!-- Formulario -->
            <div class="lg:col-span-3 bg-surface-lowest border border-outline-variant/40 rounded p-6 md:p-8">
                <h2 class="font-serif text-2xl font-semibold text-primary mb-1">{t("form.title")}</h2>
                <p class="text-sm text-on-surface-variant mb-6">{t("form.subtitle")}</p>
                <form id="email-form" class="grid grid-cols-1 sm:grid-cols-2 gap-4" novalidate>
                    <div class="sm:col-span-2">
                        <label for="cf-name" class="block label-caps text-xs text-on-surface-variant mb-1.5">{t("form.name")}</label>
                        <input id="cf-name" name="name" type="text" required autocomplete="name" class="w-full rounded border border-outline/60 bg-surface-low px-4 py-2.5 text-on-surface focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-transparent" />
                    </div>
                    <div>
                        <label for="cf-email" class="block label-caps text-xs text-on-surface-variant mb-1.5">{t("form.email")}</label>
                        <input id="cf-email" name="email" type="email" required autocomplete="email" class="w-full rounded border border-outline/60 bg-surface-low px-4 py-2.5 text-on-surface focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-transparent" />
                    </div>
                    <div>
                        <label for="cf-phone" class="block label-caps text-xs text-on-surface-variant mb-1.5">{t("form.phone")} <span class="normal-case tracking-normal text-outline">({t("form.optional")})</span></label>
                        <input id="cf-phone" name="phone" type="tel" autocomplete="tel" class="w-full rounded border border-outline/60 bg-surface-low px-4 py-2.5 text-on-surface focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-transparent" />
                    </div>
                    <div class="sm:col-span-2">
                        <label for="cf-service" class="block label-caps text-xs text-on-surface-variant mb-1.5">{t("form.service")} <span class="normal-case tracking-normal text-outline">({t("form.optional")})</span></label>
                        <select id="cf-service" name="service" class="w-full rounded border border-outline/60 bg-surface-low px-4 py-2.5 text-on-surface focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-transparent">
                            <option value="">{t("form.serviceDefault")}</option>
                            {services.map((service) => (
                                <option value={t(`service.${service}`)}>{t(`service.${service}`)}</option>
                            ))}
                        </select>
                    </div>
                    <div class="sm:col-span-2">
                        <label for="cf-message" class="block label-caps text-xs text-on-surface-variant mb-1.5">{t("form.message")}</label>
                        <textarea id="cf-message" name="message" rows="4" required placeholder={t("form.messagePlaceholder")} class="w-full rounded border border-outline/60 bg-surface-low px-4 py-2.5 text-on-surface focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-transparent"></textarea>
                    </div>
                    <div class="sm:col-span-2">
                        <button type="submit" class="w-full bg-primary-container hover:bg-primary text-on-primary font-semibold uppercase tracking-wider text-sm px-6 py-3 rounded transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-primary-container">
                            {t("form.submit")}
                        </button>
                        <p class="text-xs text-on-surface-variant mt-2 text-center">{t("form.note")}</p>
                    </div>
                </form>
            </div>

            <!-- Info lateral -->
            <div class="lg:col-span-2 space-y-8">
                <!-- Zona de servicio -->
                <div class="bg-surface-container border border-outline-variant/40 rounded p-6">
                    <h3 class="font-serif text-xl font-semibold text-primary mb-2">{t("contact.areaTitle")}</h3>
                    <p class="text-sm text-on-surface-variant mb-4">{t("contact.areaBlurb")}</p>
                    <div class="flex flex-wrap gap-2">
                        {
                            siteConfig.business.areaServed.map((area) => (
                                <span class="bg-secondary-container text-on-secondary-container label-caps text-[11px] px-3 py-1 rounded">
                                    {area}
                                </span>
                            ))
                        }
                    </div>
                    <p class="text-sm text-on-surface-variant mt-4">{t("contact.hours")}</p>
                </div>

                <!-- Preguntas comunes -->
                <div>
                    <h3 class="font-serif text-xl font-semibold text-primary mb-4">{t("contact.faqTitle")}</h3>
                    <div class="space-y-5">
                        <div>
                            <p class="font-semibold text-primary text-sm mb-1">{t("contact.faq1q")}</p>
                            <p class="text-sm text-on-surface-variant leading-relaxed">{t("contact.faq1a")}</p>
                        </div>
                        <div class="border-t border-outline-variant/30 pt-5">
                            <p class="font-semibold text-primary text-sm mb-1">{t("contact.faq2q")}</p>
                            <p class="text-sm text-on-surface-variant leading-relaxed">{t("contact.faq2a")}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script
    is:inline
    define:vars={{
        mailTo: siteConfig.author.email,
        subjectBase: t("form.subject"),
        L: {
            name: t("form.name"),
            email: t("form.email"),
            phone: t("form.phone"),
            service: t("form.service"),
            message: t("form.message"),
        },
    }}
>
    const form = document.getElementById("email-form");
    form?.addEventListener("submit", (e) => {
        e.preventDefault();
        if (!form.reportValidity()) return;
        const data = new FormData(form);
        const get = (k) => (data.get(k) || "").toString().trim();
        const name = get("name");
        const subject = `${subjectBase} - ${name}`;
        const lines = [
            `${L.name}: ${name}`,
            `${L.email}: ${get("email")}`,
            get("phone") ? `${L.phone}: ${get("phone")}` : null,
            get("service") ? `${L.service}: ${get("service")}` : null,
            "",
            `${L.message}:`,
            get("message"),
        ].filter((l) => l !== null);
        window.location.href =
            `mailto:${mailTo}?subject=${encodeURIComponent(subject)}` +
            `&body=${encodeURIComponent(lines.join("\n"))}`;
    });
</script>
