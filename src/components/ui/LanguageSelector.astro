---
import { getLangFromUrl } from "../../i18n/utils";
import { languages } from "../../i18n/ui";
import { translatePath, type Lang } from "../../i18n/routes";

const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

const flags: Record<string, string> = {
    en: "🇺🇸",
    es: "🇲🇽",
};
---

<div class="relative language-selector">
    <button
        type="button"
        class="flex items-center gap-1 min-h-11 text-gray-700 dark:text-gray-200 hover:text-blue-700 dark:hover:text-blue-400 font-medium px-4 py-2 rounded-lg transition-colors"
        aria-expanded="false"
        aria-haspopup="true"
        aria-label={lang === "es" ? "Cambiar idioma" : "Change language"}
    >
        <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"
            ></path></svg
        >
        <span class="text-xl leading-none">{flags[lang] || ""}</span>
        <span class="uppercase">{lang}</span>
        <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path></svg
        >
    </button>

    <!-- Dropdown -->
    <div
        class="language-dropdown hidden absolute right-0 mt-2 w-32 bg-white dark:bg-slate-800 rounded-lg shadow-xl z-50 border border-gray-100 dark:border-slate-700"
    >
        <ul class="py-2">
            {
                Object.entries(languages).map(([code, name]) => (
                    <li>
                        <a
                            href={translatePath(currentPath, code as Lang)}
                            class={`px-4 py-2 text-sm flex items-center gap-2 ${lang === code ? "text-blue-700 dark:text-blue-400 bg-blue-50 dark:bg-slate-700/50 font-bold" : "text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-slate-700"}`}
                        >
                            <span class="text-lg">{flags[code]}</span>
                            {name}
                        </a>
                    </li>
                ))
            }
        </ul>
    </div>
</div>

<script>
    // El componente se renderiza dos veces (nav de escritorio y menú móvil);
    // Astro deduplica este script, así que inicializamos todas las instancias.
    document.querySelectorAll(".language-selector").forEach((root) => {
        const button = root.querySelector("button");
        const dropdown = root.querySelector(".language-dropdown");
        if (!button || !dropdown) return;

        const close = () => {
            dropdown.classList.add("hidden");
            button.setAttribute("aria-expanded", "false");
        };

        button.addEventListener("click", () => {
            const nowHidden = dropdown.classList.toggle("hidden");
            button.setAttribute("aria-expanded", String(!nowHidden));
        });

        document.addEventListener("click", (e) => {
            if (!root.contains(e.target as Node)) close();
        });

        root.addEventListener("keydown", (e) => {
            if ((e as KeyboardEvent).key === "Escape") {
                close();
                button.focus();
            }
        });
    });
</script>
