---
import { getLangFromUrl } from "../../i18n/utils";
import { translatePath, type Lang } from "../../i18n/routes";

const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

const options: Lang[] = ["en", "es"];
---

<div
    class="flex items-center gap-1 label-caps text-xs"
    role="group"
    aria-label="Language"
>
    {
        options.map((code, i) => (
            <>
                {i > 0 && <span class="text-outline-variant" aria-hidden="true">/</span>}
                <a
                    href={translatePath(currentPath, code)}
                    aria-current={lang === code ? "true" : undefined}
                    class={
                        lang === code
                            ? "text-primary border-b-2 border-primary pb-0.5"
                            : "text-on-surface-variant hover:text-primary transition-colors"
                    }
                >
                    {code.toUpperCase()}
                </a>
            </>
        ))
    }
</div>
