---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
    beforeImage: ImageMetadata;
    afterImage: ImageMetadata;
    alt: string;
}

const { beforeImage, afterImage, alt } = Astro.props;
---

<div class="relative w-full aspect-[4/3] rounded-xl overflow-hidden shadow-lg">
    <img-comparison-slider class="w-full h-full">
        <div slot="first" class="w-full h-full">
            <Image
                src={beforeImage}
                alt={`Antes - ${alt}`}
                class="w-full h-full object-cover"
                widths={[768, 1024, 1920]}
                sizes="(max-width: 768px) 100vw, 1024px"
            />
            <div
                class="absolute top-4 left-4 bg-black/70 text-white px-4 py-2 rounded-lg font-semibold"
            >
                ANTES
            </div>
        </div>

        <div slot="second" class="w-full h-full">
            <Image
                src={afterImage}
                alt={`Después - ${alt}`}
                class="w-full h-full object-cover"
                widths={[768, 1024, 1920]}
                sizes="(max-width: 768px) 100vw, 1024px"
            />
            <div
                class="absolute top-4 right-4 bg-blue-600 text-white px-4 py-2 rounded-lg font-semibold"
            >
                DESPUÉS
            </div>
        </div>
    </img-comparison-slider>
</div>

<!-- Load Web Component -->
<script>
    import "img-comparison-slider";
</script>

<style is:global>
    img-comparison-slider {
        --divider-width: 2px;
        --divider-color: #fff;
        --default-handle-opacity: 1;
    }

    img-comparison-slider:focus {
        outline: none;
    }
</style>
