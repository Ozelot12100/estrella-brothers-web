---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

interface Props {
    beforeImage: ImageMetadata;
    afterImage: ImageMetadata;
    alt: string;
}

const { beforeImage, afterImage, alt } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="relative w-full aspect-[4/3] rounded-xl overflow-hidden shadow-lg">
    <img-comparison-slider class="w-full h-full">
        <div slot="first" class="w-full h-full">
            <Image
                src={beforeImage}
                alt={`${t("slider.beforeAlt")} - ${alt}`}
                class="w-full h-full object-cover"
                widths={[768, 1024, 1920]}
                sizes="(max-width: 768px) 100vw, 1024px"
            />
            <div
                class="absolute top-4 left-4 bg-primary/80 text-on-primary label-caps text-xs px-4 py-2 rounded"
            >
                {t("slider.before")}
            </div>
        </div>

        <div slot="second" class="w-full h-full">
            <Image
                src={afterImage}
                alt={`${t("slider.afterAlt")} - ${alt}`}
                class="w-full h-full object-cover"
                widths={[768, 1024, 1920]}
                sizes="(max-width: 768px) 100vw, 1024px"
            />
            <div
                class="absolute top-4 right-4 bg-primary-container text-on-primary label-caps text-xs px-4 py-2 rounded"
            >
                {t("slider.after")}
            </div>
        </div>
    </img-comparison-slider>
</div>

<!-- Load Web Component -->
<script>
    import "img-comparison-slider";
</script>

<style is:global>
    img-comparison-slider {
        --divider-width: 2px;
        --divider-color: #fff;
        --default-handle-opacity: 1;
    }

    img-comparison-slider:focus-visible {
        outline: 2px solid var(--color-primary-container);
        outline-offset: 2px;
    }
</style>
