---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { localizePath } from "../../i18n/routes";

interface Props {
    project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const {
    title,
    titleEs,
    category,
    location,
    description,
    descriptionEs,
    coverImage,
    date,
} = project.data;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const projectUrl = localizePath("projects", lang, project.id);

const displayTitle = lang === "es" ? (titleEs ?? title) : title;
const displayDescription =
    lang === "es" ? (descriptionEs ?? description) : description;

const formattedDate = new Intl.DateTimeFormat(
    lang === "es" ? "es-MX" : "en-US",
    { year: "numeric", month: "long" },
).format(date);
---

<article
    class="group h-full bg-surface-lowest border border-outline-variant/40 rounded overflow-hidden hover:border-outline transition-colors"
>
    <a href={projectUrl} class="flex flex-col h-full">
        <!-- Imagen -->
        <div class="relative aspect-[4/3] overflow-hidden bg-surface-high">
            <Image
                src={coverImage}
                alt={`${displayTitle} - ${location}`}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                widths={[400, 768]}
                sizes="(max-width: 768px) 100vw, 400px"
                loading="lazy"
            />
            <span
                class="absolute top-4 left-4 bg-primary-container text-on-primary label-caps text-[11px] px-3 py-1 rounded"
            >
                {t(`category.${category}`)}
            </span>
        </div>

        <!-- Contenido -->
        <div class="p-6 flex flex-col flex-1">
            <div class="flex items-center gap-2 text-xs text-on-surface-variant mb-2">
                <span>{location}</span>
                <span aria-hidden="true">·</span>
                <time datetime={date.toISOString()}>{formattedDate}</time>
            </div>

            <h3
                class="font-serif text-xl font-semibold text-primary mb-2 group-hover:text-secondary transition-colors"
            >
                {displayTitle}
            </h3>

            <p class="text-sm text-on-surface-variant leading-relaxed line-clamp-2">
                {displayDescription}
            </p>

            <span
                class="mt-4 inline-flex items-center gap-1 label-caps text-xs text-secondary group-hover:text-primary transition-colors"
            >
                {t("project.viewDetails")}
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </span>
        </div>
    </a>
</article>
