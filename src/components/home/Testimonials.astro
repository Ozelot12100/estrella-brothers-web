---
import { getLangFromUrl } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);

const testimonialsEs = [
    {
        name: "Carlos Rodríguez",
        role: "Propietario en Scottsdale",
        content:
            "Luis y su equipo hicieron un trabajo increíble remodelando nuestra cocina. La atención al detalle en los gabinetes y el framing fue excepcional. Fueron puntuales, limpios y muy profesionales. Altamente recomendados.",
        rating: 5,
    },
    {
        name: "María Fernández",
        role: "Propietaria en Phoenix",
        content:
            "Contratamos a Luis para hacer el framing de nuestra ampliación. El inspector de la ciudad incluso mencionó la excelente calidad del trabajo de madera. Definitivamente volveremos a contratarlo para futuros proyectos.",
        rating: 5,
    },
    {
        name: "David Smith",
        role: "Propietario en Mesa",
        content:
            "El deck personalizado que construyeron en nuestro patio trasero superó todas nuestras expectativas. Fueron muy transparentes durante todo el proceso y terminaron a tiempo y dentro del presupuesto.",
        rating: 5,
    },
];

const testimonialsEn = [
    {
        name: "Carlos Rodríguez",
        role: "Homeowner in Scottsdale",
        content:
            "Luis and his team did an incredible job remodeling our kitchen. The attention to detail on the cabinets and framing was exceptional. They were on time, clean, and very professional. Highly recommended.",
        rating: 5,
    },
    {
        name: "María Fernández",
        role: "Homeowner in Phoenix",
        content:
            "We hired Luis to do the framing for our addition. The city inspector even mentioned the excellent quality of the woodwork. We will definitely hire him again for future projects.",
        rating: 5,
    },
    {
        name: "David Smith",
        role: "Homeowner in Mesa",
        content:
            "The custom deck they built in our backyard exceeded all our expectations. They were very transparent throughout the process and finished on time and within budget.",
        rating: 5,
    },
];

const testimonials = lang === "en" ? testimonialsEn : testimonialsEs;

const isEn = lang === "en";
const badgeText = isEn ? "Testimonials" : "Testimonios";
const titleText = isEn
    ? "What Our Clients Say"
    : "Lo Que Dicen Nuestros Clientes";
const subtitleText = isEn
    ? "Our clients' satisfaction is our greatest pride and our best letter of recommendation."
    : "La satisfacción de nuestros clientes es nuestro mayor orgullo y nuestra mejor carta de presentación.";
---

<section class="max-w-7xl mx-auto px-4 md:px-16 py-20 md:py-28">
    <div class="max-w-3xl mb-14 reveal-on-scroll reveal-fade-up">
        <p class="label-caps text-xs text-secondary mb-4">{badgeText}</p>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-primary mb-4">
            {titleText}
        </h2>
        <div class="w-24 h-1 bg-outline-variant/60"></div>
        <p class="mt-4 text-on-surface-variant">{subtitleText}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-2">
        {
            testimonials.map((testimonial, index) => (
                <div class={`bg-surface-low border border-outline-variant/40 p-8 rounded reveal-on-scroll reveal-fade-up delay-${((index % 3) + 1) * 100}`}>
                    <div class="text-secondary mb-6 flex gap-0.5">
                        {[...Array(testimonial.rating)].map(() => (
                            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
                                <path d="M12 17.27L18.18 21L16.54 13.97L22 9.24L14.81 8.63L12 2L9.19 8.63L2 9.24L7.46 13.97L5.82 21L12 17.27Z" />
                            </svg>
                        ))}
                    </div>

                    <p class="font-serif text-lg text-on-surface leading-relaxed mb-8 italic">
                        “{testimonial.content}”
                    </p>

                    <div class="flex items-center gap-4 border-t border-outline-variant/30 pt-6">
                        <div class="w-12 h-12 bg-secondary-container text-on-secondary-container rounded-full flex items-center justify-center font-bold text-xl uppercase font-serif">
                            {testimonial.name.charAt(0)}
                        </div>
                        <div>
                            <h4 class="font-semibold text-primary">{testimonial.name}</h4>
                            <p class="text-sm text-on-surface-variant">{testimonial.role}</p>
                        </div>
                    </div>
                </div>
            ))
        }
    </div>
</section>
