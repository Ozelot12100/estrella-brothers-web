---
import { Image } from "astro:assets";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { localizePath } from "../../i18n/routes";
import Button from "../ui/Button.astro";
import aboutImg from "@/assets/projects/beam-ceiling-vault.webp";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
    id="about"
    class="bg-surface-container border-y border-outline-variant/30"
>
    <div
        class="max-w-7xl mx-auto px-4 md:px-16 py-20 md:py-28 grid md:grid-cols-2 gap-10 lg:gap-16 items-center"
    >
        <!-- Imagen -->
        <div
            class="relative h-[360px] md:h-[560px] rounded overflow-hidden border border-outline-variant/40 reveal-on-scroll reveal-fade-right"
        >
            <Image
                src={aboutImg}
                alt="Estrella Brothers"
                class="w-full h-full object-cover"
                widths={[480, 800]}
                sizes="(max-width: 768px) 100vw, 600px"
                loading="lazy"
            />
        </div>

        <!-- Texto -->
        <div class="reveal-on-scroll reveal-fade-left">
            <p class="label-caps text-xs text-secondary mb-4">{t("about.badge")}</p>
            <h2
                class="font-serif text-3xl md:text-5xl font-bold text-primary leading-tight mb-6"
            >
                {t("about.title1")}<span class="text-secondary">{t("about.titleHighlight")}</span>{t("about.title2")}
            </h2>
            <p class="text-lg text-on-surface-variant leading-relaxed mb-8">
                {t("about.p1")}
            </p>

            <!-- Zona de servicio -->
            <div class="flex items-center gap-3 mb-8">
                <svg class="w-7 h-7 text-secondary shrink-0" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z"></path>
                </svg>
                <div>
                    <p class="label-caps text-xs text-primary">{t("about.serving")}</p>
                    <p class="text-sm text-on-surface-variant">{t("about.servingCities")}</p>
                </div>
            </div>

            <!-- Stats -->
            <div class="grid grid-cols-2 gap-6 border-t border-outline-variant/40 pt-8 mb-8">
                <div>
                    <p class="font-serif text-4xl font-bold text-primary">100+</p>
                    <p class="label-caps text-xs text-on-surface-variant mt-1">
                        {t("about.statProjects")}
                    </p>
                </div>
                <div>
                    <p class="font-serif text-4xl font-bold text-primary">2020</p>
                    <p class="label-caps text-xs text-on-surface-variant mt-1">
                        {t("about.established")}
                    </p>
                </div>
            </div>

            <Button href={localizePath("contact", lang)} variant="secondary" size="md">
                {t("about.cta")}
            </Button>
        </div>
    </div>
</section>
