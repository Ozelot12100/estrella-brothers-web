---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
    class="py-24 bg-white dark:bg-slate-900 overflow-hidden transition-colors duration-300"
>
    <div class="container mx-auto px-4">
        <div class="flex flex-col lg:flex-row items-center gap-16">
            <!-- Image Content -->
            <div class="w-full lg:w-1/2 relative">
                <div
                    class="relative z-10 rounded-2xl overflow-hidden shadow-2xl"
                >
                    <img
                        src="https://images.unsplash.com/photo-1581428982868-e410dd047a90?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                        alt="Estrella Brothers trabajando en carpintería"
                        class="w-full h-[500px] object-cover hover:scale-105 transition-transform duration-700"
                        loading="lazy"
                    />
                </div>
                <!-- Decorative element -->
                <div
                    class="absolute -bottom-6 -right-6 w-full h-full border-4 border-blue-600 rounded-2xl z-0 hidden md:block"
                >
                </div>

                <!-- Experience Badge -->
                <div
                    class="absolute top-8 -left-8 bg-blue-600 text-white p-6 rounded-xl shadow-xl z-20 animate-bounce-slow"
                >
                    <div class="text-4xl font-bold mb-1">10+</div>
                    <div class="text-sm font-medium uppercase tracking-wider">
                        Años de<br />Experiencia
                    </div>
                </div>
            </div>

            <!-- Text Content -->
            <div class="w-full lg:w-1/2">
                <div
                    class="inline-block px-4 py-1.5 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 font-semibold rounded-full mb-6"
                >
                    {t("about.badge")}
                </div>
                <h2
                    class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-gray-100 mb-6 leading-tight"
                >
                    {t("about.title1")}<span
                        class="text-blue-600 dark:text-blue-400"
                        >{t("about.titleHighlight")}</span
                    >{t("about.title2")}
                </h2>
                <div
                    class="space-y-4 text-lg text-gray-600 dark:text-gray-300 mb-8"
                >
                    <p>
                        {t("about.p1")}
                    </p>
                    <p>
                        {t("about.p2")}
                    </p>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-10">
                    <div class="flex items-center gap-4">
                        <div
                            class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center text-blue-600 dark:text-blue-400 shrink-0"
                        >
                            <svg
                                class="w-6 h-6"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path></svg
                            >
                        </div>
                        <div>
                            <h4
                                class="font-bold text-gray-900 dark:text-gray-100"
                            >
                                {t("about.feature1.title")}
                            </h4>
                            <p class="text-sm text-gray-600 dark:text-gray-400">
                                {t("about.feature1.desc")}
                            </p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div
                            class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center text-blue-600 dark:text-blue-400 shrink-0"
                        >
                            <svg
                                class="w-6 h-6"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path></svg
                            >
                        </div>
                        <div>
                            <h4
                                class="font-bold text-gray-900 dark:text-gray-100"
                            >
                                {t("about.feature2.title")}
                            </h4>
                            <p class="text-sm text-gray-600 dark:text-gray-400">
                                {t("about.feature2.desc")}
                            </p>
                        </div>
                    </div>
                </div>

                <a
                    href={lang === "en" ? "/en/contacto" : "/contacto"}
                    class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-white transition-all duration-200 bg-blue-600 border border-transparent rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-600"
                >
                    {t("about.cta")}
                    <svg
                        class="w-5 h-5 ml-2"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
                    >
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    .animate-bounce-slow {
        animation: bounce 3s infinite;
    }
    @keyframes bounce {
        0%,
        100% {
            transform: translateY(-5%);
            animation-timing-function: cubic-bezier(0.8, 0, 1, 1);
        }
        50% {
            transform: translateY(0);
            animation-timing-function: cubic-bezier(0, 0, 0.2, 1);
        }
    }
</style>
