---
import { getLangFromUrl } from "../../i18n/utils";
import { localizePath } from "../../i18n/routes";

const lang = getLangFromUrl(Astro.url);

const faqsEs = [
    {
        question: "¿Qué respalda su trabajo?",
        answer: "Desde el 2020 hemos completado con éxito alrededor de 100 proyectos en el área de Phoenix. Respaldamos cada trabajo con garantía por escrito en la mano de obra, materiales de calidad y apego a los códigos de construcción vigentes. Con gusto le compartimos fotos y referencias de proyectos anteriores.",
    },
    {
        question: "¿Cómo funciona el proceso de cotización?",
        answer: "El proceso es simple y sin compromiso. Nos contacta con su idea, agendamos una visita a su propiedad para tomar medidas y entender sus necesidades exactas, y en un plazo de 24-48 horas le entregamos un presupuesto detallado.",
    },
    {
        question: "¿En qué áreas de Arizona trabajan?",
        answer: "Principalmente prestamos servicios en el Área Metropolitana de Phoenix, incluyendo Scottsdale, Mesa, Tempe, Chandler, Gilbert y ciudades colindantes.",
    },
    {
        question: "¿Garantizan sus trabajos de carpintería y remodelación?",
        answer: "Absolutamente. Ofrecemos garantía por escrito en toda la mano de obra. Utilizamos materiales de alta calidad y seguimos los códigos de construcción vigentes para asegurar que el trabajo perdure.",
    },
    {
        question: "¿Se encargan de los permisos con la ciudad?",
        answer: "Sí. Según el tamaño y tipo de proyecto, le ayudamos a preparar los planos y a coordinar los permisos con la ciudad correspondiente, guiándole en cada paso para que el proceso sea sencillo.",
    },
];

const faqsEn = [
    {
        question: "What stands behind your work?",
        answer: "Since 2020 we have successfully completed around 100 projects across the Phoenix area. We back every job with a written workmanship warranty, quality materials, and compliance with current building codes. We're happy to share photos and references from past projects.",
    },
    {
        question: "How does the estimating process work?",
        answer: "The process is simple and obligation-free. You contact us with your idea, we schedule a visit to your property to take measurements and understand your exact needs, and within 24-48 hours we provide a detailed estimate.",
    },
    {
        question: "What areas in Arizona do you serve?",
        answer: "We primarily serve the Phoenix Metropolitan Area, including Scottsdale, Mesa, Tempe, Chandler, Gilbert, and surrounding cities.",
    },
    {
        question: "Do you guarantee your carpentry and remodeling work?",
        answer: "Absolutely. We offer a written guarantee on all workmanship. We use high-quality materials and follow current building codes to ensure the work is built to last.",
    },
    {
        question: "Do you handle city permits?",
        answer: "Yes. Depending on the size and scope of the project, we help you prepare the plans and coordinate the permits with the city, guiding you through each step so the process is easy.",
    },
];

const faqs = lang === "en" ? faqsEn : faqsEs;

const isEn = lang === "en";
const badgeText = "FAQ";
const titleText = isEn ? "Frequently Asked Questions" : "Preguntas Frecuentes";
const subtitleText = isEn
    ? "We answer the most common questions about our services and work processes."
    : "Resolvemos las dudas más comunes sobre nuestros servicios y procesos de trabajo.";
const contactQuestionText = isEn
    ? "Have any other questions?"
    : "¿Tiene alguna otra pregunta?";
const contactLinkText = isEn
    ? "Contact us directly &rarr;"
    : "Contáctenos directamente &rarr;";
const contactHref = localizePath("contact", lang);
---

<section class="bg-surface-container border-y border-outline-variant/30">
    <div class="max-w-4xl mx-auto px-4 md:px-16 py-20 md:py-28">
        <div class="text-center mb-14">
            <p class="label-caps text-xs text-secondary mb-4">{badgeText}</p>
            <h2 class="font-serif text-3xl md:text-4xl font-semibold text-primary mb-4">
                {titleText}
            </h2>
            <p class="text-on-surface-variant">{subtitleText}</p>
        </div>

        <div class="space-y-3">
            {
                faqs.map((faq, index) => (
                    <div class="border border-outline-variant/40 rounded overflow-hidden bg-surface-lowest hover:border-outline transition-colors">
                        <button
                            class="faq-button w-full flex items-center justify-between p-5 md:p-6 text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-container focus-visible:ring-inset rounded"
                            aria-expanded="false"
                            aria-controls={`faq-answer-${index}`}
                        >
                            <span class="font-serif text-lg font-semibold text-primary pr-8">
                                {faq.question}
                            </span>
                            <div class="w-9 h-9 bg-secondary-container text-on-secondary-container rounded-full flex items-center justify-center shrink-0 transition-transform duration-300 faq-icon">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                </svg>
                            </div>
                        </button>
                        <div
                            id={`faq-answer-${index}`}
                            class="faq-content h-0 overflow-hidden transition-all duration-300 ease-in-out opacity-0"
                        >
                            <div class="p-5 md:p-6 pt-0 text-on-surface-variant leading-relaxed border-t border-outline-variant/30">
                                {faq.answer}
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>

        <div class="mt-12 text-center">
            <p class="text-on-surface-variant mb-4">{contactQuestionText}</p>
            <a
                href={contactHref}
                class="label-caps text-xs text-secondary hover:text-primary hover:underline transition-colors"
                set:html={contactLinkText}
            />
        </div>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const faqButtons = document.querySelectorAll(".faq-button");
        let currentlyOpen: HTMLElement | null = null;
        let currentIcon: HTMLElement | null = null;

        faqButtons.forEach((button) => {
            button.addEventListener("click", () => {
                const content = button.nextElementSibling as HTMLElement;
                const icon = button.querySelector(".faq-icon") as HTMLElement;
                const isExpanded =
                    button.getAttribute("aria-expanded") === "true";

                // Close currently open FAQ if it's not the one being clicked
                if (currentlyOpen && currentlyOpen !== content) {
                    currentlyOpen.style.height = "0px";
                    currentlyOpen.style.opacity = "0";
                    currentlyOpen.previousElementSibling?.setAttribute(
                        "aria-expanded",
                        "false",
                    );
                    if (currentIcon) {
                        currentIcon.style.transform = "rotate(0deg)";
                    }
                }

                if (!isExpanded) {
                    // Open the clicked FAQ
                    content.style.height = content.scrollHeight + "px";
                    content.style.opacity = "1";
                    button.setAttribute("aria-expanded", "true");
                    icon.style.transform = "rotate(180deg)";
                    currentlyOpen = content;
                    currentIcon = icon;
                } else {
                    // Close the clicked FAQ
                    content.style.height = "0px";
                    content.style.opacity = "0";
                    button.setAttribute("aria-expanded", "false");
                    icon.style.transform = "rotate(0deg)";
                    currentlyOpen = null;
                    currentIcon = null;
                }
            });
        });
    });
</script>
