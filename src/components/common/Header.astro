---
import { Image } from "astro:assets";
import { siteConfig } from "../../config/site";
import logoImg from "@/assets/logo/logo-transparente.png";
import ThemeToggle from "../ui/ThemeToggle.astro";
import LanguageSelector from "../ui/LanguageSelector.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { localizePath } from "../../i18n/routes";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navItems = [
    { name: t("nav.home"), href: localizePath("home", lang) },
    { name: t("nav.projects"), href: localizePath("projects", lang) },
    { name: t("nav.contact"), href: localizePath("contact", lang) },
];
---

<header
    class="fixed top-0 left-0 right-0 z-50 bg-white/95 dark:bg-slate-900/95 backdrop-blur-sm border-b border-gray-200 dark:border-slate-800 transition-colors duration-300"
>
    <nav class="container mx-auto px-4 py-4" aria-label={t("a11y.mainNav")}>
        <div class="flex items-center justify-between">
            <!-- Logo -->
            <a
                href={localizePath("home", lang)}
                class="flex items-center"
                aria-label="Estrella Brothers - Home"
            >
                <Image
                    src={logoImg}
                    alt="Estrella Brothers - Carpentry & Framing"
                    class="h-14 md:h-16 w-auto object-contain drop-shadow-md hover:scale-105 transition-transform duration-300"
                    height={64}
                    densities={[1, 2]}
                    loading="eager"
                />
            </a>

            <!-- Desktop Navigation -->
            <div class="hidden md:flex items-center gap-6">
                <ul class="flex items-center gap-6 mr-4">
                    {
                        navItems.map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    class="text-gray-700 dark:text-gray-300 hover:text-blue-700 dark:hover:text-blue-400 font-medium transition-colors"
                                >
                                    {item.name}
                                </a>
                            </li>
                        ))
                    }
                </ul>

                <div
                    class="flex items-center space-x-2 border-l border-gray-200 dark:border-slate-700 pl-4"
                >
                    <LanguageSelector />
                    <ThemeToggle />
                </div>

                <a
                    href={`tel:${siteConfig.author.phone.e164}`}
                    class="ml-4 bg-blue-700 hover:bg-blue-800 text-white px-5 py-2 rounded-lg font-semibold transition-colors"
                >
                    {t("nav.call")}
                </a>
            </div>

            <!-- Mobile Menu Control -->
            <div class="flex items-center gap-2 md:hidden">
                <!-- CTA de llamar siempre visible en móvil -->
                <a
                    href={`tel:${siteConfig.author.phone.e164}`}
                    class="inline-flex items-center justify-center min-w-11 min-h-11 bg-blue-700 hover:bg-blue-800 text-white rounded-lg transition-colors"
                    aria-label={t("nav.callNow")}
                >
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                        ></path>
                    </svg>
                </a>
                <ThemeToggle />
                <button
                    id="mobile-menu-button"
                    class="inline-flex items-center justify-center min-w-11 min-h-11 p-2 text-gray-700 dark:text-gray-300"
                    aria-label="Toggle menu"
                    aria-expanded="false"
                    aria-controls="mobile-menu"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden pt-4 pb-2">
            <div
                class="flex items-center justify-between mb-4 pb-4 border-b border-gray-200 dark:border-slate-700"
            >
                <span
                    class="text-sm font-medium text-gray-500 dark:text-gray-400"
                    >{t("header.language")}</span
                >
                <LanguageSelector />
            </div>

            <ul class="space-y-2">
                {
                    navItems.map((item) => (
                        <li>
                            <a
                                href={item.href}
                                class="block py-2 text-gray-700 dark:text-gray-300 hover:text-blue-700 dark:hover:text-blue-400"
                            >
                                {item.name}
                            </a>
                        </li>
                    ))
                }
                <li
                    class="pt-4 mt-4 border-t border-gray-200 dark:border-slate-700"
                >
                    <a
                        href={`tel:${siteConfig.author.phone.e164}`}
                        class="block w-full bg-blue-700 hover:bg-blue-800 text-white px-6 py-3 rounded-lg font-semibold text-center"
                    >
                        {t("nav.callNow")}
                    </a>
                </li>
            </ul>
        </div>
    </nav>
</header>

<script>
    const button = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("mobile-menu");

    button?.addEventListener("click", () => {
        const nowHidden = menu?.classList.toggle("hidden");
        button.setAttribute("aria-expanded", String(!nowHidden));
    });
</script>
