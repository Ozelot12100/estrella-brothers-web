---
import LanguageSelector from "../ui/LanguageSelector.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { localizePath } from "../../i18n/routes";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const home = localizePath("home", lang);

const navItems = [
    { name: t("nav.services"), href: `${home}#services` },
    { name: t("nav.projects"), href: localizePath("projects", lang) },
    { name: t("nav.about"), href: `${home}#about` },
];
---

<!-- Barra superior (escritorio) -->
<header
    class="hidden md:block sticky top-0 z-40 bg-surface/95 backdrop-blur-sm border-b border-outline-variant/30"
>
    <div class="flex justify-between items-center px-8 lg:px-16 py-4 max-w-7xl mx-auto">
        <a
            href={home}
            class="font-serif text-2xl font-bold text-primary tracking-tight"
            aria-label="Estrella Brothers - Home"
        >
            Estrella Brothers
        </a>
        <nav class="flex items-center gap-8" aria-label={t("a11y.mainNav")}>
            {
                navItems.map((item) => (
                    <a
                        href={item.href}
                        class="label-caps text-xs text-on-surface-variant hover:text-primary transition-colors"
                    >
                        {item.name}
                    </a>
                ))
            }
            <span class="h-4 w-px bg-outline-variant/60" aria-hidden="true"></span>
            <LanguageSelector />
            <a
                href={localizePath("contact", lang)}
                class="bg-primary-container text-on-primary px-5 py-2.5 rounded label-caps text-xs hover:bg-primary transition-colors shadow-sm"
            >
                {t("nav.getQuote")}
            </a>
        </nav>
    </div>
</header>

<!-- Barra superior (móvil, simplificada — la navegación vive en la barra inferior) -->
<header
    class="md:hidden sticky top-0 z-40 bg-surface/95 backdrop-blur-sm border-b border-outline-variant/30 px-4 py-3 flex justify-between items-center"
>
    <a
        href={home}
        class="font-serif text-xl font-bold text-primary tracking-tight"
        aria-label="Estrella Brothers - Home"
    >
        Estrella Brothers
    </a>
    <LanguageSelector />
</header>
