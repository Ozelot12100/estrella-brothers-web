---
import { siteConfig } from "../../config/site";
import ThemeToggle from "../ui/ThemeToggle.astro";
import LanguageSelector from "../ui/LanguageSelector.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navItems = [
    { name: t("nav.home"), href: lang === "es" ? "/" : "/en/" },
    {
        name: t("nav.projects"),
        href: lang === "es" ? "/proyectos" : "/en/proyectos",
    },
    {
        name: t("nav.contact"),
        href: lang === "es" ? "/contacto" : "/en/contacto",
    },
];
---

<header
    class="fixed top-0 left-0 right-0 z-50 bg-white/95 dark:bg-slate-900/95 backdrop-blur-sm border-b border-gray-200 dark:border-slate-800 transition-colors duration-300"
>
    <nav class="container mx-auto px-4 py-4">
        <div class="flex items-center justify-between">
            <!-- Logo -->
            <a
                href={lang === "es" ? "/" : "/en/"}
                class="text-2xl font-bold text-gray-900 dark:text-gray-100"
            >
                {siteConfig.name}
            </a>

            <!-- Desktop Navigation -->
            <div class="hidden md:flex items-center gap-6">
                <ul class="flex items-center gap-6 mr-4">
                    {
                        navItems.map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    class="text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-colors"
                                >
                                    {item.name}
                                </a>
                            </li>
                        ))
                    }
                </ul>

                <div
                    class="flex items-center space-x-2 border-l border-gray-200 dark:border-slate-700 pl-4"
                >
                    <LanguageSelector />
                    <ThemeToggle />
                </div>

                <a
                    href={`tel:${siteConfig.author.phone}`}
                    class="ml-4 bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg font-semibold transition-colors"
                >
                    Llamar
                </a>
            </div>

            <!-- Mobile Menu Control -->
            <div class="flex items-center gap-2 md:hidden">
                <ThemeToggle />
                <button
                    id="mobile-menu-button"
                    class="p-2 text-gray-700 dark:text-gray-300"
                    aria-label="Toggle menu"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden pt-4 pb-2">
            <div
                class="flex items-center justify-between mb-4 pb-4 border-b border-gray-200 dark:border-slate-700"
            >
                <span
                    class="text-sm font-medium text-gray-500 dark:text-gray-400"
                    >Idioma:</span
                >
                <LanguageSelector />
            </div>

            <ul class="space-y-2">
                {
                    navItems.map((item) => (
                        <li>
                            <a
                                href={item.href}
                                class="block py-2 text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400"
                            >
                                {item.name}
                            </a>
                        </li>
                    ))
                }
                <li
                    class="pt-4 mt-4 border-t border-gray-200 dark:border-slate-700"
                >
                    <a
                        href={`tel:${siteConfig.author.phone}`}
                        class="block w-full bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-semibold text-center"
                    >
                        Llamar Ahora
                    </a>
                </li>
            </ul>
        </div>
    </nav>
</header>

<script>
    const button = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("mobile-menu");

    button?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
    });
</script>
