---
import { siteConfig } from "../../config/site";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300">
    <div class="container mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Company Info -->
            <div>
                <h3 class="text-white text-xl font-bold mb-4">
                    {siteConfig.name}
                </h3>
                <p class="text-sm mb-4">
                    {lang === "es"
                        ? "Servicios profesionales de carpintería y remodelaciones en el área de Phoenix, Arizona."
                        : "Professional carpentry and remodeling services in the Phoenix, Arizona area."}
                </p>
                <p class="text-sm">
                    {lang === "es"
                        ? "Calidad, puntualidad y profesionalismo garantizado."
                        : "Quality, punctuality and professionalism guaranteed."}
                </p>
            </div>

            <!-- Service Areas -->
            <div>
                <h4 class="text-white font-semibold mb-4">
                    {lang === "es" ? "Áreas de Servicio" : "Service Areas"}
                </h4>
                <ul class="space-y-2 text-sm">
                    {
                        siteConfig.business.areaServed.map((area) => (
                            <li>{area}, AZ</li>
                        ))
                    }
                </ul>
            </div>

            <!-- Contact & Socials -->
            <div>
                <h4 class="text-white font-semibold mb-4">
                    {lang === "es" ? "Contacto" : "Contact"}
                </h4>
                <ul class="space-y-3 text-sm mb-6">
                    <li>
                        <a
                            href={`tel:${siteConfig.author.phone.e164}`}
                            class="hover:text-white flex items-center gap-2"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                ></path></svg
                            >
                            {siteConfig.author.phone.display}
                        </a>
                    </li>
                    <li>
                        <a
                            href={`mailto:${siteConfig.author.email}`}
                            class="hover:text-white flex items-center gap-2"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                ></path></svg
                            >
                            {siteConfig.author.email}
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="border-t border-gray-800 mt-8 pt-8 flex flex-col md:flex-row justify-between items-center text-sm text-gray-400">
            <p class="mb-4 md:mb-0">
                © {currentYear}
                {siteConfig.name}. {lang === "es" ? "Todos los derechos reservados." : "All rights reserved."}
            </p>
            <p class="flex items-center gap-1 group">
                {t('footer.developer')}
                <a 
                    href="https://www.davidramirez.com.mx/" 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="font-semibold text-blue-500 hover:text-blue-400 transition-colors"
                >
                    David A. Ramírez
                </a>
            </p>
        </div>
    </div>
</footer>
