---
import { siteConfig } from "../../config/site";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { localizePath } from "../../i18n/routes";
import { waLink } from "../../utils/contact";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="relative z-[2] bg-primary text-on-primary/80">
    <div class="max-w-7xl mx-auto px-4 md:px-16 py-16 grid grid-cols-1 md:grid-cols-3 gap-12">
        <!-- Marca -->
        <div>
            <h2 class="font-serif text-3xl font-bold text-on-primary mb-4 tracking-tight">
                {siteConfig.name}
            </h2>
            <p class="text-sm leading-relaxed mb-3 max-w-xs">
                {t("footer.tagline1")}
            </p>
            <p class="text-sm leading-relaxed max-w-xs">
                {t("footer.tagline2")}
            </p>
        </div>

        <!-- Áreas de servicio -->
        <div>
            <h3 class="label-caps text-xs text-on-primary-container mb-4">
                {t("footer.areas")}
            </h3>
            <ul class="space-y-2 text-sm">
                {
                    siteConfig.business.areaServed.map((area) => (
                        <li>{area}, AZ</li>
                    ))
                }
            </ul>
        </div>

        <!-- Contacto -->
        <div>
            <h3 class="label-caps text-xs text-on-primary-container mb-4">
                {t("footer.contact")}
            </h3>
            <ul class="space-y-3 text-sm">
                <li>
                    <a
                        href={`tel:${siteConfig.author.phone.e164}`}
                        class="hover:text-on-primary transition-colors"
                    >
                        {siteConfig.author.phone.display}
                    </a>
                </li>
                <li>
                    <a
                        href={`mailto:${siteConfig.author.email}`}
                        class="hover:text-on-primary transition-colors break-all"
                    >
                        {siteConfig.author.email}
                    </a>
                </li>
                <li>
                    <a
                        href={waLink(t("whatsapp.message"))}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-on-primary transition-colors"
                    >
                        WhatsApp
                    </a>
                </li>
                <li>
                    <a
                        href={localizePath("contact", lang)}
                        class="hover:text-on-primary transition-colors"
                    >
                        {t("nav.getQuote")}
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <div class="border-t border-on-primary/15">
        <div class="max-w-7xl mx-auto px-4 md:px-16 py-6 flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-on-primary/60">
            <p>© {currentYear} {siteConfig.name} Carpentry. {t("footer.rights")}</p>
            <p class="flex items-center gap-1">
                {t("footer.developer")}
                <a
                    href="https://www.davidramirez.com.mx/?utm_source=estrellabrothers&utm_medium=footer&utm_campaign=credito"
                    target="_blank"
                    rel="noopener noreferrer author"
                    class="font-semibold text-on-primary/90 hover:text-on-primary transition-colors"
                >
                    David A. Ramírez
                </a>
            </p>
        </div>
    </div>
</footer>
